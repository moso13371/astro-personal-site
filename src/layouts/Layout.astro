---
import '../styles/global.css';
import navData from '../content/navigation.json';
import themeData from '../content/theme.json';

interface Props {
	title: string;
	description?: string;
	articlePublishDate?: Date;
}

const { 
	title, 
	description = "WONGLING — 超心理學與非常規意識狀態研究個人網站。致力於探討異常感知、心物交互作用的實證與科學分析。", 
	articlePublishDate 
} = Astro.props;

// Use Astro.url.pathname to handle active links
const currentPath = Astro.url.pathname;
const isArticle = currentPath.startsWith('/articles/') && currentPath !== '/articles';

// Dynamic Schema.org JSON-LD for AI crawlers
const schemaData = isArticle ? {
	"@context": "https://schema.org",
	"@type": "ScholarlyArticle",
	"headline": title,
	"description": description,
	"author": {
		"@type": "Person",
		"name": "WONGLING"
	},
	"datePublished": articlePublishDate ? articlePublishDate.toISOString() : undefined,
	"publisher": {
		"@type": "Organization",
		"name": "WONGLING Research Lab"
	}
} : {
	"@context": "https://schema.org",
	"@type": "WebSite",
	"name": "WONGLING",
	"alternateName": "WONGLING - 超心理學研究工作者",
	"url": "https://parawongling.com/",
	"description": description
};
---

<!doctype html>
<html lang="zh-TW">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | WONGLING</title>
		
		<!-- Google Fonts: Cormorant Garamond (English Serif), Noto Serif TC (Chinese Serif), and Inter (Sans-serif) -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300&family=Inter:wght@300;400;500&family=Noto+Serif+TC:wght@300;400;600&display=swap" rel="stylesheet">
		
		<!-- Structured Data for Search Engines & AI Crawlers -->
		<script type="application/ld+json" set:html={JSON.stringify(schemaData)} />

		<!-- Dynamic typography styles controlled by Keystatic backend -->
		<style define:vars={{
			titleSize: themeData.titleSize || '2.8rem',
			professionSize: themeData.professionSize || '1.15rem'
		}}>
			:root {
				--title-font-size: var(--titleSize);
				--profession-font-size: var(--professionSize);
			}
		</style>
	</head>
	<body>
		<!-- Wabi-Sabi tactile paper grain overlay -->
		<div class="grain"></div>
		
		<!-- Interactive Quantum/Dust Particles Canvas -->
		<canvas id="wabi-particles"></canvas>

		<div class="container">
			<header>
				<div class="logo">
					<a href="/">WONGLING</a>
				</div>
				<!-- Collapsed Dropdown Menu -->
				<div class="menu-dropdown">
					<button class="menu-trigger" aria-haspopup="true" aria-expanded="false">
						選單 MENU <span class="chevron">↓</span>
					</button>
					<div class="menu-dropdown-content">
						<nav>
							<ul>
								{navData.links.map((link) => {
									const isActive = link.href === '/' 
										? currentPath === '/' 
										: currentPath === link.href || currentPath.startsWith(link.href + '/');
									return (
										<li>
											<a href={link.href} class={isActive ? 'active' : ''}>
												{link.label}
											</a>
										</li>
									);
								})}
							</ul>
						</nav>
					</div>
				</div>
			</header>
			<main>
				<slot />
			</main>
            <footer style="margin-top: 8rem; padding-top: 2.5rem; border-top: 1px solid var(--border-color); text-align: center; color: var(--text-muted); font-size: 0.8rem; letter-spacing: 2px; font-family: var(--font-serif);">
                &copy; {new Date().getFullYear()} WONGLING. Parapsychology Research.
            </footer>
		</div>

		<script>
			class DustParticle {
				x: number = 0;
				y: number = 0;
				size: number = 0;
				vx: number = 0;
				vy: number = 0;
				alpha: number = 0;
				baseAlpha: number = 0;
				baseSize: number = 0;
				pulsePhase: number = 0;
				pulseSpeed: number = 0;
				canvasWidth: number;
				canvasHeight: number;
				isHome: boolean = false;

				constructor(w: number, h: number, isHome: boolean) {
					this.canvasWidth = w;
					this.canvasHeight = h;
					this.isHome = isHome;
					this.reset(true);
				}

				reset(initiallyRandomY = false) {
					this.x = Math.random() * this.canvasWidth;
					this.y = initiallyRandomY ? Math.random() * this.canvasHeight : this.canvasHeight + 20;
					
					const rand = Math.random();
					const sizeMultiplier = this.isHome ? 1.5 : 1.0;
					if (rand > 0.88) {
						this.baseSize = (6 + Math.random() * 12) * sizeMultiplier; // big out of focus dust
						this.baseAlpha = 0.08 + Math.random() * 0.10;
					} else {
						this.baseSize = (1.2 + Math.random() * 3.5) * sizeMultiplier; // small sharp dust
						this.baseAlpha = 0.22 + Math.random() * 0.28;
					}

					this.alpha = this.baseAlpha;
					// Meditative slower drift speeds (0.5x speed on home page)
					const speedMultiplier = this.isHome ? 0.5 : 1.0;
					this.vx = (Math.random() - 0.5) * 0.06 * speedMultiplier;
					this.vy = (Math.random() - 0.5) * 0.06 * speedMultiplier;
					
					this.pulsePhase = Math.random() * Math.PI * 2;
					this.pulseSpeed = (0.005 + Math.random() * 0.01) * (this.isHome ? 0.6 : 1.0);
				}

				update(mouseX: number, mouseY: number, mouseActive: boolean, isTransitioning: boolean) {
					if (isTransitioning) {
						// Explode particles outward from center
						const cx = this.canvasWidth / 2;
						const cy = this.canvasHeight / 2;
						const dx = this.x - cx;
						const dy = this.y - cy;
						const dist = Math.sqrt(dx * dx + dy * dy) || 1;

						this.vx += (dx / dist) * 0.45;
						this.vy += (dy / dist) * 0.45;
						this.x += this.vx;
						this.y += this.vy;
						this.alpha -= 0.008; // Slightly faster fade
						return;
					}

					// Slower organic drift
					this.x += this.vx;
					this.y += this.vy;

					// Less brownian noise for smoother flow
					this.vx += (Math.random() - 0.5) * 0.004;
					this.vy += (Math.random() - 0.5) * 0.004;

					// Slower speed caps
					const speedCap = this.isHome ? 0.10 : 0.20;
					this.vx = Math.max(-speedCap, Math.min(speedCap, this.vx));
					this.vy = Math.max(-speedCap, Math.min(speedCap, this.vy));

					// Pronounced size breathing (pulsating size change is more obvious)
					this.pulsePhase += this.pulseSpeed;
					this.size = Math.max(0.1, this.baseSize * (0.50 + 0.65 * Math.sin(this.pulsePhase)));

					// Mouse repulsion
					if (mouseActive) {
						const dx = this.x - mouseX;
						const dy = this.y - mouseY;
						const dist = Math.sqrt(dx * dx + dy * dy);
						if (dist < 180) {
							const force = (180 - dist) / 180 * 0.08;
							this.vx += (dx / (dist + 1)) * force;
							this.vy += (dy / (dist + 1)) * force;
						}
					}

					// Boundary wraps
					if (this.x < -30) this.x = this.canvasWidth + 30;
					if (this.x > this.canvasWidth + 30) this.x = -30;
					if (this.y < -30) this.y = this.canvasHeight + 30;
					if (this.y > this.canvasHeight + 30) this.y = -30;
				}

				draw(ctx: CanvasRenderingContext2D) {
					if (this.alpha <= 0) return;
					ctx.beginPath();
					const grad = ctx.createRadialGradient(this.x, this.y, 0, this.x, this.y, this.size);
					
					// Concrete gray particles
					grad.addColorStop(0, `rgba(192, 196, 204, ${this.alpha})`);
					grad.addColorStop(0.3, `rgba(192, 196, 204, ${this.alpha * 0.4})`);
					grad.addColorStop(1, 'rgba(192, 196, 204, 0)');
					
					ctx.fillStyle = grad;
					ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
					ctx.fill();
				}
			}

			function initParticles() {
				const canvas = document.getElementById('wabi-particles') as HTMLCanvasElement;
				if (!canvas) return;
				const ctx = canvas.getContext('2d');
				if (!ctx) return;

				let w = canvas.width = window.innerWidth;
				let h = canvas.height = window.innerHeight;

				const isHome = window.location.pathname === '/' || window.location.pathname === '';
				const densityDivider = isHome ? 2750 : 11000;
				const maxCount = isHome ? 520 : 130;

				let particles: DustParticle[] = [];
				const particleCount = Math.min(maxCount, Math.floor((w * h) / densityDivider));
				
				for (let i = 0; i < particleCount; i++) {
					particles.push(new DustParticle(w, h, isHome));
				}

				let mouse = { x: 0, y: 0, active: false };
				let isTransitioning = false;
				let transitionTarget = '';

				window.addEventListener('mousemove', (e) => {
					mouse.x = e.clientX;
					mouse.y = e.clientY;
					mouse.active = true;
				});

				window.addEventListener('mouseleave', () => {
					mouse.active = false;
				});

				// Custom event listener for page transitions (excludes header)
				window.addEventListener('page-transition', (e: any) => {
					isTransitioning = true;
					transitionTarget = e.detail.targetUrl;
					
					// Fade out ONLY the main content element, leaving header fixed!
					const mainContent = document.querySelector('main');
					if (mainContent) {
						(mainContent as HTMLElement).style.transition = 'opacity 0.22s cubic-bezier(0.16, 1, 0.3, 1), transform 0.22s cubic-bezier(0.16, 1, 0.3, 1)';
						(mainContent as HTMLElement).style.opacity = '0';
						(mainContent as HTMLElement).style.transform = 'scale(0.99)';
					}

					// Fast, crisp page redirection after 220ms
					setTimeout(() => {
						window.location.href = transitionTarget;
					}, 220);
				});

				window.addEventListener('resize', () => {
					w = canvas.width = window.innerWidth;
					h = canvas.height = window.innerHeight;
					particles.forEach(p => {
						p.canvasWidth = w;
						p.canvasHeight = h;
					});
				});

				// Pulse touch/click shockwave
				window.addEventListener('mousedown', (e) => {
					if (isTransitioning) return;
					particles.forEach(p => {
						const dx = p.x - e.clientX;
						const dy = p.y - e.clientY;
						const dist = Math.sqrt(dx * dx + dy * dy);
						if (dist < 200) {
							const impulse = (200 - dist) / 200 * 5;
							p.vx += (dx / (dist + 1)) * impulse;
							p.vy += (dy / (dist + 1)) * impulse;
						}
					});
				});

				function animate() {
					if (!ctx || !canvas) return;
					ctx.clearRect(0, 0, w, h);

					particles.forEach(p => {
						p.update(mouse.x, mouse.y, mouse.active, isTransitioning);
						p.draw(ctx);
					});

					requestAnimationFrame(animate);
				}

				animate();
			}

			// Initialize
			if (document.readyState === 'complete' || document.readyState === 'interactive') {
				initParticles();
			} else {
				document.addEventListener('DOMContentLoaded', initParticles);
			}

			// Intercept links click to trigger transition & close dropdown
			document.addEventListener('DOMContentLoaded', () => {
				const links = document.querySelectorAll('header nav a, .logo a');
				const content = document.querySelector('.menu-dropdown-content');
				const trigger = document.querySelector('.menu-trigger');

				links.forEach(link => {
					link.addEventListener('click', (e) => {
						const href = link.getAttribute('href');
						const target = link.getAttribute('target');
						if (href && href.startsWith('/') && target !== '_blank' && !e.metaKey && !e.ctrlKey && !e.shiftKey) {
							e.preventDefault();
							// Close dropdown immediately on link click
							if (content && trigger) {
								content.classList.remove('show');
								trigger.setAttribute('aria-expanded', 'false');
							}
							window.dispatchEvent(new CustomEvent('page-transition', { detail: { targetUrl: href } }));
						}
					});
				});

				// Dropdown Menu Toggle Script
				if (trigger && content) {
					trigger.addEventListener('click', (e) => {
						e.stopPropagation();
						const isOpen = content.classList.contains('show');
						if (isOpen) {
							content.classList.remove('show');
							trigger.setAttribute('aria-expanded', 'false');
						} else {
							content.classList.add('show');
							trigger.setAttribute('aria-expanded', 'true');
						}
					});

					// Close when clicking anywhere outside
					document.addEventListener('click', () => {
						content.classList.remove('show');
						trigger.setAttribute('aria-expanded', 'false');
					});
				}
			});
		</script>
	</body>
</html>

