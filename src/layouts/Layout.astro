---
import '../styles/global.css';
import navData from '../content/navigation.json';
import themeData from '../content/theme.json';

interface Props {
	title: string;
	description?: string;
	articlePublishDate?: Date;
}

const { 
	title, 
	description = "WONGLING — 超心理學與非常規意識狀態研究個人網站。致力於探討異常感知、心物交互作用的實證與科學分析。", 
	articlePublishDate 
} = Astro.props;

// Use Astro.url.pathname to handle active links
const currentPath = Astro.url.pathname;
const isArticle = currentPath.startsWith('/articles/') && currentPath !== '/articles';

// Dynamic Schema.org JSON-LD for AI crawlers
const schemaData = isArticle ? {
	"@context": "https://schema.org",
	"@type": "ScholarlyArticle",
	"headline": title,
	"description": description,
	"author": {
		"@type": "Person",
		"name": "WONGLING"
	},
	"datePublished": articlePublishDate ? articlePublishDate.toISOString() : undefined,
	"publisher": {
		"@type": "Organization",
		"name": "WONGLING Research Lab"
	}
} : {
	"@context": "https://schema.org",
	"@type": "WebSite",
	"name": "WONGLING",
	"alternateName": "WONGLING - 超心理學研究工作者",
	"url": "https://parawongling.com/",
	"description": description
};
---

<!doctype html>
<html lang="zh-TW">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | WONGLING</title>
		
		<!-- Google Fonts: Cormorant Garamond (English Serif), Noto Serif TC (Chinese Serif), and Inter (Sans-serif) -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300&family=Inter:wght@300;400;500&family=Noto+Serif+TC:wght@300;400;600&display=swap" rel="stylesheet">
		
		<!-- Structured Data for Search Engines & AI Crawlers -->
		<script type="application/ld+json" set:html={JSON.stringify(schemaData)} />

		<!-- Dynamic typography styles controlled by Keystatic backend -->
		<style define:vars={{
			titleSize: themeData.titleSize || '2.8rem',
			professionSize: themeData.professionSize || '1.15rem'
		}}>
			:root {
				--title-font-size: var(--titleSize);
				--profession-font-size: var(--professionSize);
			}
		</style>
	</head>
	<body>
		<!-- Wabi-Sabi tactile paper grain overlay -->
		<div class="grain"></div>
		
		<!-- Interactive Quantum/Dust Particles Canvas -->
		<canvas id="wabi-particles"></canvas>

		<div class="container">
			<header>
				<div class="logo">
					<a href="/">WONGLING</a>
				</div>
				<!-- Collapsed Dropdown Menu -->
				<div class="menu-dropdown">
					<button class="menu-trigger" aria-haspopup="true" aria-expanded="false">
						選單 MENU <span class="chevron">↓</span>
					</button>
					<div class="menu-dropdown-content">
						<nav>
							<ul>
								{navData.links.map((link) => {
									const isActive = link.href === '/' 
										? currentPath === '/' 
										: currentPath === link.href || currentPath.startsWith(link.href + '/');
									return (
										<li>
											<a href={link.href} class={isActive ? 'active' : ''}>
												{link.label}
											</a>
										</li>
									);
								})}
							</ul>
						</nav>
					</div>
				</div>
			</header>
			<main>
				<slot />
			</main>
            <footer style="margin-top: 8rem; padding-top: 2.5rem; border-top: 1px solid var(--border-color); text-align: center; color: var(--text-muted); font-size: 0.8rem; letter-spacing: 2px; font-family: var(--font-serif);">
                &copy; {new Date().getFullYear()} WONGLING. Parapsychology Research.
            </footer>
		</div>

		<script>
			let audioCtx: any = null;
			let oscLeft: any = null;
			let oscRight: any = null;
			let filter: any = null;
			let delay: any = null;
			let masterGain: any = null;
			let isAudioActive = false;

			function initAudio() {
				audioCtx = new (window.AudioContext || (window as any).webkitAudioContext)();
				
				// Left oscillator at 130 Hz (deep baritone, Bluetooth ANC safe)
				oscLeft = audioCtx.createOscillator();
				oscLeft.type = 'sine';
				oscLeft.frequency.value = 130;

				// Right oscillator at 134 Hz (4Hz difference creates deep Delta/Theta waves)
				oscRight = audioCtx.createOscillator();
				oscRight.type = 'sine';
				oscRight.frequency.value = 134;

				// Create stereo panning
				const pannerLeft = audioCtx.createStereoPanner ? audioCtx.createStereoPanner() : null;
				const pannerRight = audioCtx.createStereoPanner ? audioCtx.createStereoPanner() : null;

				// Warm, dark lowpass filter
				filter = audioCtx.createBiquadFilter();
				filter.type = 'lowpass';
				filter.frequency.value = 200;
				filter.Q.value = 1.0;

				// Delay and feedback loop for spacey reverb
				delay = audioCtx.createDelay();
				delay.delayTime.value = 0.35;
				const feedback = audioCtx.createGain();
				feedback.gain.value = 0.42;

				masterGain = audioCtx.createGain();
				masterGain.gain.value = 0.0; // starts silent

				// Connections
				if (pannerLeft && pannerRight) {
					pannerLeft.pan.value = -1.0;
					pannerRight.pan.value = 1.0;
					oscLeft.connect(pannerLeft).connect(filter);
					oscRight.connect(pannerRight).connect(filter);
				} else {
					oscLeft.connect(filter);
					oscRight.connect(filter);
				}

				filter.connect(masterGain);
				filter.connect(delay);
				delay.connect(feedback);
				feedback.connect(delay);
				delay.connect(masterGain);

				masterGain.connect(audioCtx.destination);

				oscLeft.start();
				oscRight.start();

				return masterGain;
			}

			function updateBinauralFrequencies(ny: number) {
				if (!audioCtx || !isAudioActive || !oscLeft || !oscRight) return;
				const isPhaseShifted = (window as any).isPhaseShifted || false;
				if (isPhaseShifted) {
					// 190Hz / 180Hz (10Hz Alpha beating modulated slightly by Y coordinate: 8Hz to 14Hz difference)
					oscLeft.frequency.setTargetAtTime(180, audioCtx.currentTime, 0.1);
					oscRight.frequency.setTargetAtTime(180 + (8.0 + ny * 6.0), audioCtx.currentTime, 0.1);
				} else {
					// 130Hz / 134Hz (4Hz Delta/Theta beating modulated slightly by Y coordinate: 1.5Hz to 7Hz difference)
					oscLeft.frequency.setTargetAtTime(130, audioCtx.currentTime, 0.1);
					oscRight.frequency.setTargetAtTime(130 + (1.5 + ny * 5.5), audioCtx.currentTime, 0.1);
				}
			}

			// Expose sound toggle globally
			(window as any).toggleBinauralSound = () => {
				if (!audioCtx) {
					initAudio();
					isAudioActive = true;
					masterGain.gain.setValueAtTime(0, audioCtx.currentTime);
					masterGain.gain.linearRampToValueAtTime(0.06, audioCtx.currentTime + 1.5);
					return true;
				} else {
					if (audioCtx.state === 'suspended') {
						audioCtx.resume();
						isAudioActive = true;
						masterGain.gain.setValueAtTime(0, audioCtx.currentTime);
						masterGain.gain.linearRampToValueAtTime(0.06, audioCtx.currentTime + 1.5);
						return true;
					} else if (audioCtx.state === 'running') {
						isAudioActive = false;
						masterGain.gain.linearRampToValueAtTime(0, audioCtx.currentTime + 0.5);
						setTimeout(() => {
							if (!isAudioActive && audioCtx) audioCtx.suspend();
						}, 500);
						return false;
					}
				}
			};

			// Listen to dimension phase toggle event to update frequencies immediately
			window.addEventListener('phase-change', (e: any) => {
				const isShifted = e.detail?.isShifted || false;
				(window as any).isPhaseShifted = isShifted;
				const currentY = (window as any).lastMouseY !== undefined ? (window as any).lastMouseY : 0.5;
				updateBinauralFrequencies(currentY);
			});

			class DustParticle {
				x: number = 0;
				y: number = 0;
				size: number = 0;
				vx: number = 0;
				vy: number = 0;
				alpha: number = 0;
				baseAlpha: number = 0;
				baseSize: number = 0;
				pulsePhase: number = 0;
				pulseSpeed: number = 0;
				canvasWidth: number;
				canvasHeight: number;
				isHome: boolean = false;
				isArchive: boolean = false;
				archiveLabel: string = "";
				shiftedLabel: string = "";

				constructor(w: number, h: number, isHome: boolean) {
					this.canvasWidth = w;
					this.canvasHeight = h;
					this.isHome = isHome;
					this.reset(true);
				}

				reset(initiallyRandomY = false) {
					this.x = Math.random() * this.canvasWidth;
					this.y = initiallyRandomY ? Math.random() * this.canvasHeight : this.canvasHeight + 20;
					
					const rand = Math.random();
					const sizeMultiplier = this.isHome ? 1.5 : 1.0;
					if (rand > 0.88) {
						this.baseSize = (6 + Math.random() * 12) * sizeMultiplier; // big out of focus dust
						this.baseAlpha = 0.08 + Math.random() * 0.10;
					} else {
						this.baseSize = (1.2 + Math.random() * 3.5) * sizeMultiplier; // small sharp dust
						this.baseAlpha = 0.22 + Math.random() * 0.28;
					}

					this.alpha = this.baseAlpha;
					// Meditative slower drift speeds (0.5x speed on home page)
					const speedMultiplier = this.isHome ? 0.5 : 1.0;
					this.vx = (Math.random() - 0.5) * 0.06 * speedMultiplier;
					this.vy = (Math.random() - 0.5) * 0.06 * speedMultiplier;
					
					this.pulsePhase = Math.random() * Math.PI * 2;
					this.pulseSpeed = (0.005 + Math.random() * 0.01) * (this.isHome ? 0.6 : 1.0);
				}

				update(mouseX: number, mouseY: number, mouseActive: boolean, isTransitioning: boolean) {
					if (isTransitioning) {
						// Explode particles outward from center
						const cx = this.canvasWidth / 2;
						const cy = this.canvasHeight / 2;
						const dx = this.x - cx;
						const dy = this.y - cy;
						const dist = Math.sqrt(dx * dx + dy * dy) || 1;

						this.vx += (dx / dist) * 0.45;
						this.vy += (dy / dist) * 0.45;
						this.x += this.vx;
						this.y += this.vy;
						this.alpha -= 0.008; // Slightly faster fade
						return;
					}

					// Slower organic drift
					this.x += this.vx;
					this.y += this.vy;

					// Less brownian noise for smoother flow
					this.vx += (Math.random() - 0.5) * 0.004;
					this.vy += (Math.random() - 0.5) * 0.004;

					// Slower speed caps
					const speedCap = this.isHome ? 0.10 : 0.20;
					this.vx = Math.max(-speedCap, Math.min(speedCap, this.vx));
					this.vy = Math.max(-speedCap, Math.min(speedCap, this.vy));

					// Pronounced size breathing (pulsating size change is more obvious)
					this.pulsePhase += this.pulseSpeed;
					this.size = Math.max(0.1, this.baseSize * (0.50 + 0.65 * Math.sin(this.pulsePhase)));

					// Mouse attraction / repulsion (Concept 1 & 3)
					if (mouseActive) {
						const dx = this.x - mouseX;
						const dy = this.y - mouseY;
						const dist = Math.sqrt(dx * dx + dy * dy);
						if (dist < 180) {
							if (this.isArchive && this.isHome) {
								if (dist < 120) {
									// Keyword node: freeze position when hovered so they don't drift/shake away
									this.vx = 0;
									this.vy = 0;
								}
							} else {
								// Regular Dust: organic repulsion
								const force = (180 - dist) / 180 * 0.08;
								this.vx += (dx / (dist + 1)) * force;
								this.vy += (dy / (dist + 1)) * force;
							}
						}
					}

					// Boundary wraps
					if (this.x < -30) this.x = this.canvasWidth + 30;
					if (this.x > this.canvasWidth + 30) this.x = -30;
					if (this.y < -30) this.y = this.canvasHeight + 30;
					if (this.y > this.canvasHeight + 30) this.y = -30;
				}

				draw(ctx: CanvasRenderingContext2D, mouseX: number, mouseY: number, mouseActive: boolean, isPhaseShifted: boolean) {
					if (this.alpha <= 0) return;
					ctx.beginPath();
					const grad = ctx.createRadialGradient(this.x, this.y, 0, this.x, this.y, this.size);
					
					// Particle color shifts during Phase Shift
					if (isPhaseShifted) {
						if (this.isArchive) {
							grad.addColorStop(0, `rgba(168, 85, 247, ${this.alpha * 1.5})`); // Violet archives
							grad.addColorStop(0.3, `rgba(168, 85, 247, ${this.alpha * 0.5})`);
						} else {
							grad.addColorStop(0, `rgba(52, 211, 153, ${this.alpha})`); // Emerald dust
							grad.addColorStop(0.3, `rgba(52, 211, 153, ${this.alpha * 0.4})`);
						}
					} else {
						// Standard steel gray wabi dust
						grad.addColorStop(0, `rgba(192, 196, 204, ${this.alpha})`);
						grad.addColorStop(0.3, `rgba(192, 196, 204, ${this.alpha * 0.4})`);
					}
					grad.addColorStop(1, 'rgba(192, 196, 204, 0)');
					
					ctx.fillStyle = grad;
					ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
					ctx.fill();

					// Draw archive metadata label on home page particles
					if (this.isArchive && this.isHome) {
						const labelText = isPhaseShifted ? this.shiftedLabel : this.archiveLabel;
						if (labelText) {
							const dx = this.x - mouseX;
							const dy = this.y - mouseY;
							const dist = mouseActive ? Math.sqrt(dx * dx + dy * dy) : 999;
							
							// Opacity calculation: ambient (0.15) rising to clear (0.70) when mouse is within 120px
							let labelAlpha = 0.15;
							if (dist < 120) {
								labelAlpha = 0.15 + (1.0 - dist / 120) * 0.55;
							}
							
							ctx.font = '300 9px monospace';
							if (isPhaseShifted) {
								ctx.fillStyle = `rgba(192, 132, 252, ${labelAlpha * 1.45})`; // Brighter lavender/violet tint
							} else {
								ctx.fillStyle = `rgba(255, 255, 255, ${labelAlpha})`; // White tint
							}
							
							// Draw text offset slightly
							ctx.fillText(labelText, this.x + 12, this.y + 4);
							
							// Faint indicator ring when mouse is very close
							if (dist < 70) {
								ctx.beginPath();
								ctx.arc(this.x, this.y, this.size + 4, 0, Math.PI * 2);
								ctx.strokeStyle = isPhaseShifted 
									? `rgba(192, 132, 252, ${0.16 * (1.0 - dist/70)})` 
									: `rgba(255, 255, 255, ${0.09 * (1.0 - dist/70)})`;
								ctx.stroke();
							}
						}
					}
				}
			}

			function initParticles() {
				const canvas = document.getElementById('wabi-particles') as HTMLCanvasElement;
				if (!canvas) return;
				const ctx = canvas.getContext('2d');
				if (!ctx) return;

				let w = canvas.width = window.innerWidth;
				let h = canvas.height = window.innerHeight;

				const isHome = window.location.pathname === '/' || window.location.pathname === '';
				const densityDivider = isHome ? 2750 : 11000;
				const maxCount = isHome ? 520 : 130;

				let particles: DustParticle[] = [];
				const particleCount = Math.min(maxCount, Math.floor((w * h) / densityDivider));
				
				const archiveLabels = [
					"Parapsychology",
					"Binaural Resonance",
					"Psi-Field Theory",
					"Mediumship Research",
					"Aerial Phenomena",
					"Extraterrestrial",
					"Consciousness Studies",
					"Out-of-Body",
					"Quantum Brain",
					"Psychedelic Research",
					"Supernatural Culture",
					"Sonic Healing",
					"Soundscape Dynamics",
					"Acoustic Resonance",
					"Telepathy Experiments",
					"Clairvoyance Trials",
					"Near-Death Experience",
					"Altered States",
					"Micro-PK Trials",
					"Hypnosis Studies",
					"Mind-Matter Coupling",
					"EHE Archives",
					"Folklore Traditions",
					"Anomalous Cognition"
				];

				const shiftedLabels = [
					"Esoteric Systems",
					"DMT Synthesia",
					"Sacred Geometry",
					"Astral Projection",
					"Gnostic Frequencies",
					"Shamanic Trance",
					"Occult Philosophies",
					"Archetypal Magic",
					"Theurgical Studies",
					"Mystical Theology",
					"Vibrational Medicine",
					"Alchemical Principles",
					"Solomon Seals",
					"Hermeticism",
					"Kabbalah Geometry",
					"Sigil Cognition",
					"Chakra Harmonics",
					"Entheogen Studies",
					"Spiritism Archives",
					"Runic Linguistics",
					"Daemonology Studies",
					"Preternatural Field",
					"Divine Geometry",
					"Ethereal Vectors"
				];

				const labelNodesCount = Math.min(24, particleCount);
				for (let i = 0; i < particleCount; i++) {
					const p = new DustParticle(w, h, isHome);
					if (isHome && i < labelNodesCount) {
						p.isArchive = true;
						p.archiveLabel = archiveLabels[i];
						p.shiftedLabel = shiftedLabels[i];
						p.baseAlpha = 0.40; // slightly brighter node
						p.alpha = p.baseAlpha;
					}
					particles.push(p);
				}

				let mouse = { x: 0, y: 0, active: false };
				let isTransitioning = false;
				let transitionTarget = '';

				// Unified Mouse Handler
				window.addEventListener('mousemove', (e) => {
					mouse.x = e.clientX;
					mouse.y = e.clientY;
					mouse.active = true;
					(window as any).lastMouseY = e.clientY;

					// Audio synthesizer dynamic modulation (Concept 2)
					if (audioCtx && isAudioActive && filter && oscRight) {
						const nx = mouse.x / window.innerWidth;
						const ny = mouse.y / window.innerHeight;
						// X axis modulates low-pass filter cutoff (100Hz to 250Hz)
						filter.frequency.setTargetAtTime(100 + nx * 150, audioCtx.currentTime, 0.1);
						
						updateBinauralFrequencies(ny);
					}
				});

				// Unified Mobile Touch Handlers to support phone testing
				let touchTimeout: any = null;
				const handleTouch = (e: TouchEvent) => {
					if (touchTimeout) clearTimeout(touchTimeout);
					if (e.touches && e.touches.length > 0) {
						mouse.x = e.touches[0].clientX;
						mouse.y = e.touches[0].clientY;
						mouse.active = true;
						(window as any).lastMouseY = e.touches[0].clientY;
						
						if (audioCtx && isAudioActive && filter && oscRight) {
							const nx = mouse.x / window.innerWidth;
							const ny = mouse.y / window.innerHeight;
							filter.frequency.setTargetAtTime(100 + nx * 150, audioCtx.currentTime, 0.1);
							updateBinauralFrequencies(ny);
						}
					}
				};

				window.addEventListener('touchstart', handleTouch);
				window.addEventListener('touchmove', handleTouch, { passive: true });
				window.addEventListener('touchend', () => {
					if (touchTimeout) clearTimeout(touchTimeout);
					// Release hovered node highlight and free particle positioning after 2 seconds
					touchTimeout = setTimeout(() => {
						mouse.active = false;
					}, 2000);
				});

				window.addEventListener('mouseleave', () => {
					mouse.active = false;
				});

				window.addEventListener('page-transition', (e: any) => {
					isTransitioning = true;
					transitionTarget = e.detail.targetUrl;
					
					const mainContent = document.querySelector('main');
					if (mainContent) {
						(mainContent as HTMLElement).style.transition = 'opacity 0.22s cubic-bezier(0.16, 1, 0.3, 1), transform 0.22s cubic-bezier(0.16, 1, 0.3, 1)';
						(mainContent as HTMLElement).style.opacity = '0';
						(mainContent as HTMLElement).style.transform = 'scale(0.99)';
					}

					setTimeout(() => {
						window.location.href = transitionTarget;
					}, 220);
				});

				window.addEventListener('resize', () => {
					w = canvas.width = window.innerWidth;
					h = canvas.height = window.innerHeight;
					particles.forEach(p => {
						p.canvasWidth = w;
						p.canvasHeight = h;
					});
				});

				// Simple audio unlock on mouse down
				window.addEventListener('mousedown', () => {
					if (isTransitioning) return;
					if (audioCtx && audioCtx.state === 'suspended' && isAudioActive) {
						audioCtx.resume();
					}
				});

				function animate() {
					if (!ctx || !canvas) return;
					ctx.clearRect(0, 0, w, h);

					const isPhaseShifted = (window as any).isPhaseShifted || false;

					// Find the currently hovered concept node (within 120px)
					let hoveredNode: DustParticle | null = null;
					if (mouse.active) {
						let closestDist = 120;
						particles.forEach(p => {
							if (!p.isArchive) return;
							const dx = p.x - mouse.x;
							const dy = p.y - mouse.y;
							const dist = Math.sqrt(dx * dx + dy * dy);
							if (dist < closestDist) {
								closestDist = dist;
								hoveredNode = p;
							}
						});
					}

					// 1. Draw normal background constellation lines (up to 54px)
					for (let i = 0; i < particles.length; i++) {
						for (let j = i + 1; j < particles.length; j++) {
							const dx = particles[i].x - particles[j].x;
							const dy = particles[i].y - particles[j].y;
							const dist = Math.sqrt(dx * dx + dy * dy);
							const maxDist = isHome ? 54 : 35;
							if (dist < maxDist) {
								let alphaVal = (1.0 - (dist / maxDist)) * 0.18 * (particles[i].alpha + particles[j].alpha); // Increased visibility
								let lineWidth = 0.5;

								const isConnectedToHover = hoveredNode && (particles[i] === hoveredNode || particles[j] === hoveredNode);
								if (isConnectedToHover) {
									alphaVal *= 4.5;
									lineWidth = 1.0;
								}

								ctx.beginPath();
								ctx.moveTo(particles[i].x, particles[i].y);
								ctx.lineTo(particles[j].x, particles[j].y);
								
								if (isPhaseShifted) {
									ctx.strokeStyle = isConnectedToHover 
										? `rgba(192, 132, 252, ${Math.min(0.9, alphaVal * 1.5)})` 
										: `rgba(168, 85, 247, ${alphaVal * 1.5})`; // Purple constellation
								} else {
									ctx.strokeStyle = isConnectedToHover 
										? `rgba(255, 255, 255, ${Math.min(0.7, alphaVal)})` 
										: `rgba(192, 196, 204, ${alphaVal})`;
								}
								ctx.lineWidth = lineWidth;
								ctx.stroke();
							}
						}
					}

					// 2. Draw special concept connections: nearby nodes (up to 240px) + exactly one infinite long-range dashed bridge
					if (hoveredNode) {
						let closestFarNode: DustParticle | null = null;
						let closestFarDist = 999999;

						particles.forEach(p => {
							if (!p.isArchive || p === hoveredNode) return;
							const dx = p.x - hoveredNode.x;
							const dy = p.y - hoveredNode.y;
							const dist = Math.sqrt(dx * dx + dy * dy);

							if (dist < 240) {
								const alphaVal = (1.0 - (dist / 240)) * 0.55; // Brighter thread
								ctx.beginPath();
								ctx.moveTo(hoveredNode.x, hoveredNode.y);
								ctx.lineTo(p.x, p.y);
								if (isPhaseShifted) {
									ctx.strokeStyle = `rgba(192, 132, 252, ${alphaVal})`; // Brighter lavender
								} else {
									ctx.strokeStyle = `rgba(255, 255, 255, ${alphaVal * 0.95})`; // Crisp white
								}
								ctx.lineWidth = 1.0;
								ctx.stroke();
							} else {
								// Track node outside 240px to find the closest far jump
								if (dist < closestFarDist) {
									closestFarDist = dist;
									closestFarNode = p;
								}
							}
						});

						// Draw one long-range dashed tunnel to the next closest concept node beyond 240px
						if (closestFarNode) {
							ctx.beginPath();
							ctx.moveTo(hoveredNode.x, hoveredNode.y);
							ctx.lineTo(closestFarNode.x, closestFarNode.y);
							
							const alphaVal = 0.32; // Soft glowing long-distance thread
							if (isPhaseShifted) {
								ctx.strokeStyle = `rgba(192, 132, 252, ${alphaVal})`;
							} else {
								ctx.strokeStyle = `rgba(255, 255, 255, ${alphaVal})`;
							}
							ctx.lineWidth = 0.85;
							ctx.setLineDash([2, 4]); // Dashed bridge pattern for quantum tunneling look
							ctx.stroke();
							ctx.setLineDash([]); // Reset immediately
						}
					}

					// Update & Draw particles
					particles.forEach(p => {
						p.update(mouse.x, mouse.y, mouse.active, isTransitioning);
						p.draw(ctx, mouse.x, mouse.y, mouse.active, isPhaseShifted);
					});

					requestAnimationFrame(animate);
				}

				animate();
			}

			// Initialize
			if (document.readyState === 'complete' || document.readyState === 'interactive') {
				initParticles();
			} else {
				document.addEventListener('DOMContentLoaded', initParticles);
			}

			// Intercept links click to trigger transition & close dropdown
			document.addEventListener('DOMContentLoaded', () => {
				const links = document.querySelectorAll('header nav a, .logo a');
				const content = document.querySelector('.menu-dropdown-content');
				const trigger = document.querySelector('.menu-trigger');

				links.forEach(link => {
					link.addEventListener('click', (e) => {
						const href = link.getAttribute('href');
						const target = link.getAttribute('target');
						if (href && href.startsWith('/') && target !== '_blank' && !e.metaKey && !e.ctrlKey && !e.shiftKey) {
							e.preventDefault();
							// Close dropdown immediately on link click
							if (content && trigger) {
								content.classList.remove('show');
								trigger.setAttribute('aria-expanded', 'false');
							}
							window.dispatchEvent(new CustomEvent('page-transition', { detail: { targetUrl: href } }));
						}
					});
				});

				// Dropdown Menu Toggle Script
				if (trigger && content) {
					trigger.addEventListener('click', (e) => {
						e.stopPropagation();
						const isOpen = content.classList.contains('show');
						if (isOpen) {
							content.classList.remove('show');
							trigger.setAttribute('aria-expanded', 'false');
						} else {
							content.classList.add('show');
							trigger.setAttribute('aria-expanded', 'true');
						}
					});

					// Close when clicking anywhere outside
					document.addEventListener('click', () => {
						content.classList.remove('show');
						trigger.setAttribute('aria-expanded', 'false');
					});
				}
			});
		</script>
		</body>
</html>
