---
// src/pages/about.astro
import Layout from '../layouts/Layout.astro';
import aboutData from '../content/about.json';

// Split the multiline profession string into an array of lines
const professions = aboutData.profession ? aboutData.profession.split('\n') : [];

// Academic and Professional Background — now managed via Keystatic backend
const academicBackground = (aboutData as any).academicBackground || [];

// Load dynamic research areas and timeline milestones from Keystatic dataset
const researchAreas = aboutData.researchAreas || [];
const timeline = aboutData.timeline || [];
---

<Layout title="關於 ABOUT">
	<div class="profile-header">
		<div class="profile-text">
			<h1 class="about-title">{aboutData.name}</h1>
			<div class="about-subtitle">
				{professions.map((prof) => (
					<span class="about-subtitle-line">{prof}</span>
				))}
			</div>
		</div>
		{aboutData.avatar && (
			<div class="profile-avatar-container">
				<img src={aboutData.avatar} class="profile-avatar" alt={aboutData.name} />
			</div>
		)}
	</div>

	<!-- Section: 關於 (About Biography - Serial prefix removed) -->
	<div class="content-block">
		<h2>關於</h2>
		<p style="white-space: pre-line; line-height: 2.0; color: var(--text-color); font-weight: 400; font-size: 1.05rem;">{aboutData.intro}</p>
	</div>

	<!-- Section: 學經歷 (Academic & Professional Background - Serial prefix removed) -->
	<div class="content-block">
		<h2>學經歷</h2>
		<div class="background-list">
			{academicBackground.map((item) => (
				<div class="background-item">
					<div class="background-title-row">
						<span class="background-title">{item.title}</span>
						{item.role && <span class="background-role">｜ {item.role}</span>}
					</div>
					<div class="background-en">{item.en}</div>
				</div>
			))}
		</div>
	</div>

	<!-- Section: 研究領域與關注方向 (Research Areas & Interests - Serial prefix removed) -->
	<div class="content-block">
		<h2>研究領域與關注方向</h2>
		<div class="domain-grid">
			{researchAreas.map((domain) => (
				<div class="domain-card">
					<div class="domain-card-header">
						<div class="domain-title-group">
							<h3 class="domain-category">{domain.category}</h3>
							<span class="domain-category-en">{domain.categoryEn}</span>
						</div>
					</div>
					<p class="domain-summary">{domain.summary}</p>
					<!-- Plain text list separated by clean dots -->
					<div class="domain-items">
						{domain.items.map((item, idx) => (
							<span class="domain-item-wrapper">
								<span class="domain-item-text">{item}</span>
								{idx < domain.items.length - 1 && <span class="domain-item-separator">·</span>}
							</span>
						))}
					</div>
				</div>
			))}
		</div>
	</div>

	<!-- Section: 研究理論與發展里程碑 (Theoretical Milestones - Serial prefix removed) -->
	<div class="content-block">
		<h2>研究理論與發展里程碑</h2>
		<div class="timeline-container">
			<div class="timeline-line"></div>
			{timeline.map((item) => (
				<div class="timeline-item">
					<div class="timeline-dot"></div>
					<div class="timeline-year">{item.year}</div>
					<div class="timeline-content">
						<h3 class="timeline-title">{item.title}</h3>
						<p class="timeline-desc">{item.desc}</p>
					</div>
				</div>
			))}
		</div>
	</div>
</Layout>

<style>
	.about-title {
		font-family: var(--font-serif);
		font-size: 2.0rem;
		font-weight: 300;
		letter-spacing: 2px;
		color: var(--text-color); /* Strict 2-tone */
		margin-top: 0;
		margin-bottom: 1.2rem;
	}

	.about-subtitle {
		font-family: var(--font-sans);
		font-size: 0.88rem;
		line-height: 1.65;
		color: var(--text-muted);
		letter-spacing: 1px;
	}

	.about-subtitle-line {
		display: block;
		margin-bottom: 0.45rem;
	}

	.about-subtitle-line:last-child {
		margin-bottom: 0;
	}

	.profile-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 3rem;
		margin-bottom: 4rem;
	}

	.profile-text {
		flex: 1;
	}

	.profile-avatar-container {
		flex-shrink: 0;
	}

	.profile-avatar {
		width: 140px;
		height: 140px;
		object-fit: cover;
		border-radius: 50%;
		border: 1px solid var(--border-color);
		filter: none !important;
		box-shadow: 0 5px 25px rgba(0, 0, 0, 0.25);
	}

	/* Background List Styling */
	.background-list {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		margin-top: 1.5rem;
	}

	.background-item {
		border-left: 2px solid rgba(255, 255, 255, 0.06);
		padding-left: 1.5rem;
		transition: border-color 0.4s ease;
	}

	.background-item:hover {
		border-left-color: var(--accent-color);
	}

	.background-title-row {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.75rem;
	}

	.background-title {
		font-family: var(--font-serif);
		font-size: 1.05rem;
		font-weight: 400;
		color: var(--text-color); /* Strict 2-tone */
		line-height: 1.4;
	}

	.background-role {
		font-size: 0.92rem;
		color: var(--text-color); /* Strict 2-tone */
		font-weight: 400;
		margin-left: 0.4rem;
	}

	.background-en {
		font-size: 0.78rem;
		color: var(--text-muted);
		text-transform: uppercase;
		letter-spacing: 1px;
		margin-top: 0.35rem;
	}

	/* Domain Grid Styling */
	.domain-grid {
		display: flex;
		flex-direction: column;
		gap: 2rem;
		margin-top: 2rem;
	}

	.domain-card {
		border-bottom: 1px solid rgba(255, 255, 255, 0.05);
		padding-bottom: 1.8rem;
	}

	.domain-card:last-child {
		border-bottom: none;
		padding-bottom: 0;
	}

	.domain-card-header {
		display: flex;
		align-items: flex-start;
		gap: 1.2rem;
		margin-bottom: 0.8rem;
	}

	.domain-title-group {
		display: flex;
		flex-direction: column;
	}

	.domain-category {
		font-family: var(--font-serif);
		font-size: 1.22rem;
		font-weight: 400;
		margin: 0;
		color: var(--text-color); /* Strict 2-tone */
		letter-spacing: 1.5px;
	}

	.domain-category-en {
		font-size: 0.72rem;
		color: var(--text-muted); /* Strict 2-tone */
		text-transform: uppercase;
		letter-spacing: 1px;
		margin-top: 0.3rem;
	}

	.domain-summary {
		font-size: 0.95rem;
		color: var(--text-color); /* Strict 2-tone */
		padding-left: 0;
		margin: 0.2rem 0 1.2rem 0;
		line-height: 1.75;
		font-weight: 400;
	}

	/* Muted plain text dot-separated list */
	.domain-items {
		font-size: 0.92rem;
		line-height: 1.85;
		padding-left: 0;
		letter-spacing: 0.5px;
	}

	.domain-item-wrapper {
		display: inline-block;
	}

	.domain-item-text {
		color: var(--text-muted); /* Strict 2-tone */
		transition: color 0.3s ease;
	}

	.domain-card:hover .domain-item-text {
		color: var(--text-color); /* Hover shifts to primary color */
	}

	.domain-item-separator {
		color: var(--text-muted);
		margin: 0 0.8rem;
		font-weight: 300;
		display: inline-block;
		opacity: 0.4;
	}

	/* Timeline Styling */
	.timeline-container {
		position: relative;
		margin-top: 2.5rem;
		padding-left: 1.5rem;
	}

	.timeline-line {
		position: absolute;
		left: 4.5px;
		top: 8px;
		bottom: 8px;
		width: 1px;
		background: rgba(255, 255, 255, 0.08);
	}

	.timeline-item {
		position: relative;
		display: flex;
		gap: 2rem;
		margin-bottom: 2.5rem;
	}

	.timeline-item:last-child {
		margin-bottom: 0;
	}

	.timeline-dot {
		position: absolute;
		left: 1px;
		top: 6px;
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: var(--accent-color);
		border: 2px solid #000000;
		z-index: 5;
	}

	.timeline-year {
		font-family: var(--font-sans);
		font-size: 1.05rem;
		font-weight: 500;
		color: var(--text-color); /* Strict 2-tone */
		width: 50px;
		flex-shrink: 0;
		padding-left: 15px;
		line-height: 1.4;
	}

	.timeline-content {
		flex: 1;
	}

	.timeline-title {
		font-family: var(--font-serif);
		font-size: 1.05rem;
		font-weight: 400;
		margin: 0 0 0.5rem 0;
		color: var(--text-color); /* Strict 2-tone */
		line-height: 1.4;
	}

	.timeline-desc {
		font-size: 0.92rem;
		color: var(--text-muted); /* Strict 2-tone */
		line-height: 1.7;
		margin: 0;
	}

	@media (max-width: 768px) {
		.profile-header {
			flex-direction: column-reverse;
			align-items: flex-start;
			gap: 2rem;
		}
		.profile-avatar-container {
			align-self: center;
		}
		.domain-item-wrapper {
			white-space: normal;
		}
		.timeline-item {
			flex-direction: column;
			gap: 0.5rem;
			padding-left: 1.5rem;
		}
		.timeline-dot {
			left: 1px;
		}
		.timeline-year {
			padding-left: 0;
			width: auto;
		}
	}
</style>
