---
// src/pages/about.astro
import Layout from '../layouts/Layout.astro';
import aboutData from '../content/about.json';
---

<Layout title="關於 ABOUT">
	<div class="profile-header">
		<div class="profile-text">
			<h1 class="title" style="font-family: var(--font-serif); font-weight: 300;">{aboutData.name}</h1>
			<div class="subtitle">{aboutData.profession}</div>
		</div>
		{aboutData.avatar && (
			<div class="profile-avatar-container">
				<img src={aboutData.avatar} class="profile-avatar" alt={aboutData.name} />
			</div>
		)}
	</div>

	<div class="content-block">
		<h2>關於研究</h2>
		<p style="white-space: pre-line; line-height: 2.0; color: var(--text-color); font-weight: 400; font-size: 1.05rem;">{aboutData.intro}</p>
	</div>

	<div class="content-block">
		<h2>目前專注領域</h2>
		<ul class="focus-list">
			{aboutData.focusAreas.map((area) => (
				<li>
					<span class="focus-marker"></span>
					<span class="focus-text">{area}</span>
				</li>
			))}
		</ul>
	</div>
</Layout>

<style>
	.focus-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 1.2rem;
	}

	.focus-list li {
		display: flex;
		align-items: flex-start;
		gap: 1rem;
	}

	.focus-marker {
		width: 6px;
		height: 6px;
		border: 1px solid var(--accent-color);
		transform: rotate(45deg);
		margin-top: 10px;
		flex-shrink: 0;
		opacity: 0.7;
		transition: transform 0.4s ease, background-color 0.4s ease;
	}

	.focus-list li:hover .focus-marker {
		transform: rotate(135deg);
		background-color: var(--accent-color);
	}

	.focus-text {
		color: var(--text-muted);
		line-height: 1.7;
		font-size: 1rem;
		transition: color 0.3s ease;
	}

	.focus-list li:hover .focus-text {
		color: var(--text-color);
	}

	.profile-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 3rem;
		margin-bottom: 4rem;
	}

	.profile-text {
		flex: 1;
	}

	.profile-avatar-container {
		flex-shrink: 0;
	}

	.profile-avatar {
		width: 140px;
		height: 140px;
		object-fit: cover;
		border-radius: 50%;
		border: 1px solid var(--border-color);
		filter: grayscale(0.5) contrast(1.05);
		transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
		box-shadow: 0 5px 25px rgba(0, 0, 0, 0.25);
	}

	.profile-avatar:hover {
		filter: grayscale(0) contrast(1);
		transform: scale(1.03);
		border-color: var(--accent-color);
	}

	@media (max-width: 768px) {
		.profile-header {
			flex-direction: column-reverse;
			align-items: flex-start;
			gap: 2rem;
		}
		.profile-avatar-container {
			align-self: center;
		}
	}
</style>
