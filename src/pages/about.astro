---
// src/pages/about.astro
import Layout from '../layouts/Layout.astro';
import aboutData from '../content/about.json';

// Split the multiline profession string into an array of lines
const professions = aboutData.profession ? aboutData.profession.split('\n') : [];

// Academic and Professional Background (with English translations)
const academicBackground = [
	{
		title: "天主教輔仁大學 宗教學系",
		role: "",
		en: "Department of Religious Studies, Fu Jen Catholic University"
	},
	{
		title: "TAPARA 塔帕拉超心理學與未明現象研究中心",
		role: "召集人",
		en: "TAPARA Research Center — Convener"
	},
	{
		title: "臺灣靈異研究學會",
		role: "研究員 暨 第一屆會長",
		en: "Taiwan Paranormal Research Society — Researcher & Founding President"
	},
	{
		title: "福爾摩沙超自然事件調查小組",
		role: "組長",
		en: "Formosa Paranormal Investigation Team — Team Leader"
	}
];

// Re-structured Research Areas & Interests based on the optimized user draft
const researchAreas = [
	{
		id: "01",
		category: "超心理學與未明現象",
		categoryEn: "Parapsychology & Unexplained Phenomena",
		summary: "專注於常態框架外的現象調查與機制探討。",
		items: ["超心理學 (Parapsychology)", "ESP 現象", "超常經驗 (EHE)", "靈媒模式實踐 (Mediumship Studies)", "未明飛行物 (UAP)", "地外文明等跨領域調查"]
	},
	{
		id: "02",
		category: "意識與空間維度",
		categoryEn: "Consciousness & Dimensional Studies",
		summary: "探索意識的邊界、狀態轉換與底層運作機制。",
		items: ["意識研究 (Consciousness Studies)", "超個人心理學 (Transpersonal Psychology)", "出體經驗 (OBE)", "瀕死經驗 (NDE)", "靈魂與化身假說", "迷幻研究與應用"]
	},
	{
		id: "03",
		category: "宗教、民俗與儀式現象",
		categoryEn: "Religion, Folklore & Ritual Phenomena",
		summary: "從文化與現象學視角，客觀解構信仰系統與集體經驗。",
		items: ["宗教學", "民俗學", "惡魔學 (Demonology)", "當代靈性比較", "鬼怪與靈異文化研究", "儀式與集體經驗探討"]
	},
	{
		id: "04",
		category: "聲波系統與共振實踐",
		categoryEn: "Sonic Systems & Resonance Practices",
		summary: "探究環境頻率、聲響媒材與身心意識狀態的交互作用。",
		items: ["當代身心靈系統架構", "聲音系統工作 (Sonic System Practices)", "環境聲景與文化現象之整合"]
	}
];

// Research Timeline (Theory Milestones) updated with exact user text
const timeline = [
	{
		year: "2024",
		title: "理論實驗與驗證",
		desc: "針對「意識維度假說」展開進階的相關理論實驗與驗證工作。"
	},
	{
		year: "2021",
		title: "提出「灰域」(Gray Realm) 空間理論",
		desc: "基於多年對瀕死經驗 (NDE) 與靈魂出竅經驗 (OBE) 的現象解析，建構並撰寫專屬空間理論。"
	},
	{
		year: "2018",
		title: "理論框架擴展與實證",
		desc: "進一步豐富「意識維度假說」的理論框架，並著手進行初步的實證研究探討。"
	},
	{
		year: "2016",
		title: "首次提出「意識維度假說」(Consciousness Dimension Hypothesis)",
		desc: "正式啟動多維度意識的理論建構與雛形驗證。"
	}
];
---

<Layout title="關於 ABOUT">
	<div class="profile-header">
		<div class="profile-text">
			<h1 class="about-title">{aboutData.name}</h1>
			<div class="about-subtitle">
				{professions.map((prof) => (
					<span class="about-subtitle-line">{prof}</span>
				))}
			</div>
		</div>
		{aboutData.avatar && (
			<div class="profile-avatar-container">
				<img src={aboutData.avatar} class="profile-avatar" alt={aboutData.name} />
			</div>
		)}
	</div>

	<!-- Section: 關於 (About Biography) -->
	<div class="content-block">
		<h2>關於</h2>
		<p style="white-space: pre-line; line-height: 2.0; color: var(--text-color); font-weight: 400; font-size: 1.05rem;">{aboutData.intro}</p>
	</div>

	<!-- New Section: 學經歷 (Academic & Professional Background) -->
	<div class="content-block">
		<h2>學經歷</h2>
		<div class="background-list">
			{academicBackground.map((item) => (
				<div class="background-item">
					<div class="background-title-row">
						<span class="background-title">{item.title}</span>
						{item.role && <span class="background-role">{item.role}</span>}
					</div>
					<div class="background-en">{item.en}</div>
				</div>
			))}
		</div>
	</div>

	<!-- Updated Section: 研究領域與關注方向 (Research Areas & Interests) -->
	<div class="content-block">
		<h2>研究領域與關注方向</h2>
		<div class="domain-grid">
			{researchAreas.map((domain) => (
				<div class="domain-card">
					<div class="domain-card-header">
						<span class="domain-number">{domain.id}</span>
						<div class="domain-title-group">
							<h3 class="domain-category">{domain.category}</h3>
							<span class="domain-category-en">{domain.categoryEn}</span>
						</div>
					</div>
					<!-- Summary text explaining the domain -->
					<p class="domain-summary">{domain.summary}</p>
					<!-- Pill tags under the summary -->
					<div class="domain-tags">
						{domain.items.map((item) => (
							<span class="domain-tag">{item}</span>
						))}
					</div>
				</div>
			))}
		</div>
	</div>

	<!-- Updated Section: 研究理論與發展里程碑 (Theoretical Milestones) -->
	<div class="content-block">
		<h2>研究理論與發展里程碑</h2>
		<div class="timeline-container">
			<div class="timeline-line"></div>
			{timeline.map((item) => (
				<div class="timeline-item">
					<div class="timeline-dot"></div>
					<div class="timeline-year">{item.year}</div>
					<div class="timeline-content">
						<h3 class="timeline-title">{item.title}</h3>
						<p class="timeline-desc">{item.desc}</p>
					</div>
				</div>
			))}
		</div>
	</div>
</Layout>

<style>
	.about-title {
		font-family: var(--font-serif);
		font-size: 2.0rem;
		font-weight: 300;
		letter-spacing: 2px;
		color: #ffffff;
		margin-top: 0;
		margin-bottom: 1.2rem;
	}

	.about-subtitle {
		font-family: var(--font-sans);
		font-size: 0.88rem;
		line-height: 1.65;
		color: var(--text-muted);
		letter-spacing: 1px;
	}

	.about-subtitle-line {
		display: block;
		margin-bottom: 0.45rem;
	}

	.about-subtitle-line:last-child {
		margin-bottom: 0;
	}

	.profile-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 3rem;
		margin-bottom: 4rem;
	}

	.profile-text {
		flex: 1;
	}

	.profile-avatar-container {
		flex-shrink: 0;
	}

	.profile-avatar {
		width: 140px;
		height: 140px;
		object-fit: cover;
		border-radius: 50%;
		border: 1px solid var(--border-color);
		filter: none !important;
		box-shadow: 0 5px 25px rgba(0, 0, 0, 0.25);
	}

	/* Background List Styling */
	.background-list {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		margin-top: 1.5rem;
	}

	.background-item {
		border-left: 2px solid rgba(255, 255, 255, 0.06);
		padding-left: 1.5rem;
		transition: border-color 0.4s ease;
	}

	.background-item:hover {
		border-left-color: var(--accent-color);
	}

	.background-title-row {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.75rem;
	}

	.background-title {
		font-size: 1.05rem;
		font-weight: 500;
		color: #ffffff;
		line-height: 1.4;
	}

	.background-role {
		font-size: 0.85rem;
		color: var(--accent-color);
		background: rgba(255, 255, 255, 0.05);
		border: 1px solid rgba(255, 255, 255, 0.1);
		padding: 2px 8px;
		font-weight: 400;
	}

	.background-en {
		font-size: 0.78rem;
		color: var(--text-muted);
		text-transform: uppercase;
		letter-spacing: 1px;
		margin-top: 0.35rem;
	}

	/* Domain Grid Styling */
	.domain-grid {
		display: flex;
		flex-direction: column;
		gap: 2rem;
		margin-top: 2rem;
	}

	.domain-card {
		border-bottom: 1px solid rgba(255, 255, 255, 0.05);
		padding-bottom: 1.8rem;
	}

	.domain-card:last-child {
		border-bottom: none;
		padding-bottom: 0;
	}

	.domain-card-header {
		display: flex;
		align-items: flex-start;
		gap: 1.2rem;
		margin-bottom: 0.8rem;
	}

	.domain-number {
		font-family: var(--font-sans);
		font-size: 0.9rem;
		font-weight: 500;
		color: var(--accent-color);
		opacity: 0.8;
		letter-spacing: 1px;
		margin-top: 2px;
	}

	.domain-title-group {
		display: flex;
		flex-direction: column;
	}

	.domain-category {
		font-size: 1.15rem;
		font-weight: 400;
		margin: 0;
		color: #ffffff;
		letter-spacing: 1.5px;
	}

	.domain-category-en {
		font-size: 0.72rem;
		color: var(--text-muted);
		text-transform: uppercase;
		letter-spacing: 1px;
		margin-top: 0.25rem;
	}

	.domain-summary {
		font-size: 0.92rem;
		color: var(--text-muted);
		padding-left: 2.2rem;
		margin: 0 0 1rem 0;
		line-height: 1.6;
	}

	.domain-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
		padding-left: 2.2rem;
	}

	.domain-tag {
		font-size: 0.88rem;
		color: var(--text-color);
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid rgba(255, 255, 255, 0.06);
		padding: 5px 12px;
		transition: all 0.3s ease;
	}

	.domain-tag:hover {
		color: #ffffff;
		border-color: rgba(255, 255, 255, 0.15);
		background: rgba(255, 255, 255, 0.06);
	}

	/* Timeline Styling */
	.timeline-container {
		position: relative;
		margin-top: 2.5rem;
		padding-left: 1.5rem;
	}

	.timeline-line {
		position: absolute;
		left: 4.5px;
		top: 8px;
		bottom: 8px;
		width: 1px;
		background: rgba(255, 255, 255, 0.08);
	}

	.timeline-item {
		position: relative;
		display: flex;
		gap: 2rem;
		margin-bottom: 2.5rem;
	}

	.timeline-item:last-child {
		margin-bottom: 0;
	}

	.timeline-dot {
		position: absolute;
		left: 1px;
		top: 6px;
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: var(--accent-color);
		border: 2px solid #000000;
		z-index: 5;
	}

	.timeline-year {
		font-family: var(--font-sans);
		font-size: 1.05rem;
		font-weight: 500;
		color: var(--accent-color);
		width: 50px;
		flex-shrink: 0;
		padding-left: 15px;
		line-height: 1.4;
	}

	.timeline-content {
		flex: 1;
	}

	.timeline-title {
		font-size: 1.05rem;
		font-weight: 400;
		margin: 0 0 0.5rem 0;
		color: #ffffff;
		line-height: 1.4;
	}

	.timeline-desc {
		font-size: 0.92rem;
		color: var(--text-muted);
		line-height: 1.7;
		margin: 0;
	}

	@media (max-width: 768px) {
		.profile-header {
			flex-direction: column-reverse;
			align-items: flex-start;
			gap: 2rem;
		}
		.profile-avatar-container {
			align-self: center;
		}
		.domain-summary, .domain-tags {
			padding-left: 0;
		}
		.timeline-item {
			flex-direction: column;
			gap: 0.5rem;
			padding-left: 1.5rem;
		}
		.timeline-dot {
			left: 1px;
		}
		.timeline-year {
			padding-left: 0;
			width: auto;
		}
	}
</style>
