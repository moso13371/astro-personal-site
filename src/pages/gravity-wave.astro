---
// src/pages/gravity-wave.astro
---

<!doctype html>
<html lang="zh-TW">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>重力波與時空漣漪演示 | WONGLING</title>
		<!-- Google Fonts: Inter and Noto Serif TC -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&family=Noto+Serif+TC:wght@300;400&display=swap" rel="stylesheet">
		<style>
			body, html {
				margin: 0;
				padding: 0;
				width: 100%;
				height: 100%;
				overflow: hidden;
				background-color: #000000;
				font-family: 'Inter', 'Noto Serif TC', sans-serif;
				color: #ffffff;
				user-select: none;
			}

			#gw-canvas {
				display: block;
				width: 100vw;
				height: 100vh;
				z-index: 1;
				position: absolute;
				top: 0;
				left: 0;
			}

			.overlay {
				position: absolute;
				z-index: 10;
				pointer-events: none;
				width: 100%;
				height: 100%;
				display: flex;
				flex-direction: column;
				justify-content: space-between;
				box-sizing: border-box;
				padding: 2.5rem;
			}

			.interactive-layer {
				position: absolute;
				z-index: 5;
				width: 100%;
				height: 100%;
				top: 0;
				left: 0;
				cursor: crosshair;
			}

			.back-btn {
				pointer-events: auto;
				color: rgba(255, 255, 255, 0.5);
				text-decoration: none;
				font-size: 0.85rem;
				letter-spacing: 2px;
				text-transform: uppercase;
				transition: all 0.4s ease;
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
				border: 1px solid rgba(255, 255, 255, 0.1);
				padding: 8px 16px;
				background: rgba(10, 10, 10, 0.6);
				backdrop-filter: blur(10px);
				-webkit-backdrop-filter: blur(10px);
			}

			.back-btn:hover {
				color: #ffffff;
				border-color: #ffffff;
				transform: translateX(-3px);
			}

			.control-box {
				pointer-events: auto;
				position: absolute;
				top: 2.5rem;
				right: 2.5rem;
				z-index: 20;
				width: 250px;
				background: rgba(15, 16, 18, 0.7);
				border: 1px solid rgba(255, 255, 255, 0.08);
				backdrop-filter: blur(15px);
				-webkit-backdrop-filter: blur(15px);
				padding: 1.5rem;
				display: flex;
				flex-direction: column;
				gap: 1.2rem;
				animation: fadeIn 1s ease;
			}

			.control-box-title {
				font-size: 0.8rem;
				font-weight: 500;
				margin: 0 0 0.2rem 0;
				letter-spacing: 2px;
				color: #c0c4cc;
				border-bottom: 1px solid rgba(255, 255, 255, 0.1);
				padding-bottom: 0.5rem;
			}

			.control-group {
				display: flex;
				flex-direction: column;
				gap: 0.4rem;
			}

			.control-group label {
				font-size: 0.75rem;
				color: rgba(255, 255, 255, 0.6);
				letter-spacing: 1px;
				display: flex;
				justify-content: space-between;
			}

			.control-group label span {
				color: #ffffff;
				font-weight: 500;
			}

			.control-group input[type="range"] {
				-webkit-appearance: none;
				width: 100%;
				height: 2px;
				background: rgba(255, 255, 255, 0.15);
				outline: none;
				margin: 8px 0;
			}

			.control-group input[type="range"]::-webkit-slider-thumb {
				-webkit-appearance: none;
				appearance: none;
				width: 10px;
				height: 10px;
				border-radius: 50%;
				background: #ffffff;
				cursor: pointer;
				transition: transform 0.1s ease;
			}

			.control-group input[type="range"]::-webkit-slider-thumb:hover {
				transform: scale(1.3);
			}

			.info-panel {
				align-self: flex-start;
				text-align: left;
				background: rgba(10, 10, 10, 0.6);
				padding: 1.5rem 2.2rem;
				border: 1px solid rgba(255, 255, 255, 0.08);
				backdrop-filter: blur(10px);
				-webkit-backdrop-filter: blur(10px);
				margin-bottom: 0;
				max-width: 500px;
			}

			.info-title {
				font-family: 'Noto Serif TC', serif;
				font-size: 1.15rem;
				font-weight: 300;
				letter-spacing: 2px;
				margin-top: 0;
				margin-bottom: 0.5rem;
				color: #ffffff;
			}

			.info-desc {
				font-size: 0.8rem;
				color: rgba(255, 255, 255, 0.5);
				line-height: 1.7;
				letter-spacing: 1px;
				margin: 0;
			}

			@keyframes fadeIn {
				from { opacity: 0; transform: translateY(-10px); }
				to { opacity: 1; transform: translateY(0); }
			}

			@media (max-width: 768px) {
				.overlay {
					padding: 1.5rem;
				}
				.control-box {
					top: auto;
					bottom: 1.5rem;
					right: 1.5rem;
					left: 1.5rem;
					width: auto;
					max-width: none;
				}
				.info-panel {
					display: none; /* Hide description on mobile to avoid overlap */
				}
			}
		</style>
	</head>
	<body>
		<canvas id="gw-canvas"></canvas>

		<!-- Transparent pointer event catcher for canvas interaction -->
		<div id="interactive-overlay" class="interactive-layer"></div>

		<!-- UI Layer -->
		<div class="overlay">
			<div>
				<a href="/" class="back-btn">
					&larr; 返回官網
				</a>
			</div>
			
			<div class="info-panel">
				<h2 class="info-title">重力波與時空幾何演示</h2>
				<p class="info-desc">
					模擬二元黑洞互繞產生的時空漣漪。您可以拖曳或點擊滑鼠，在時空中放置一個重力干擾源，觀察引力透鏡與時空幾何的局部扭曲。
				</p>
			</div>
		</div>

		<!-- Floating Parameter Control Box -->
		<div class="control-box">
			<h3 class="control-box-title">控制面板 CONTROLS</h3>
			
			<div class="control-group">
				<label>繞行頻率 (Speed): <span id="val-speed">0.035</span></label>
				<input type="range" id="param-speed" min="0.005" max="0.10" step="0.005" value="0.035">
			</div>

			<div class="control-group">
				<label>波形振幅 (Amplitude): <span id="val-amp">30</span></label>
				<input type="range" id="param-amp" min="5" max="80" step="5" value="30">
			</div>

			<div class="control-group">
				<label>波形波速 (Wave Speed): <span id="val-c">7.5</span></label>
				<input type="range" id="param-c" min="4.0" max="15.0" step="0.5" value="7.5">
			</div>

			<div class="control-group">
				<label>黑洞質量 (BH Mass): <span id="val-mass">4</span></label>
				<input type="range" id="param-mass" min="2" max="10" step="1" value="4">
			</div>

			<div class="control-group">
				<label>引力扭曲 (Mouse Gravity): <span id="val-mouse">30</span></label>
				<input type="range" id="param-mouse" min="0" max="80" step="5" value="30">
			</div>
		</div>

		<script>
			const canvas = document.getElementById('gw-canvas');
			const ctx = canvas.getContext('2d');
			const overlay = document.getElementById('interactive-overlay');

			let width = canvas.width = window.innerWidth;
			let height = canvas.height = window.innerHeight;

			// UI parameters elements
			const paramSpeed = document.getElementById('param-speed');
			const paramAmp = document.getElementById('param-amp');
			const paramC = document.getElementById('param-c');
			const paramMass = document.getElementById('param-mass');
			const paramMouse = document.getElementById('param-mouse');

			const valSpeed = document.getElementById('val-speed');
			const valAmp = document.getElementById('val-amp');
			const valC = document.getElementById('val-c');
			const valMass = document.getElementById('val-mass');
			const valMouse = document.getElementById('val-mouse');

			// Current simulation state
			let omega = parseFloat(paramSpeed.value);
			let A0 = parseFloat(paramAmp.value);
			let c = parseFloat(paramC.value);
			let bhMass = parseInt(paramMass.value);
			let mouseMass = parseInt(paramMouse.value);

			// Dynamic value updates
			paramSpeed.addEventListener('input', (e) => { omega = parseFloat(e.target.value); valSpeed.innerText = e.target.value; });
			paramAmp.addEventListener('input', (e) => { A0 = parseFloat(e.target.value); valAmp.innerText = e.target.value; });
			paramC.addEventListener('input', (e) => { c = parseFloat(e.target.value); valC.innerText = e.target.value; });
			paramMass.addEventListener('input', (e) => { bhMass = parseInt(e.target.value); valMass.innerText = e.target.value; });
			paramMouse.addEventListener('input', (e) => { mouseMass = parseInt(e.target.value); valMouse.innerText = e.target.value; });

			// Grid parameters
			let gridPoints = [];
			const spacingX = 22; 
			const spacingY = 22;

			function initGrid() {
				gridPoints = [];
				const cols = Math.ceil(width / spacingX) + 2;
				const rows = Math.ceil(height / spacingY) + 2;

				for (let x = -1; x < cols; x++) {
					for (let y = -1; y < rows; y++) {
						gridPoints.push({
							origX: x * spacingX,
							origY: y * spacingY
						});
					}
				}
			}

			initGrid();

			// Handle Resize
			window.addEventListener('resize', () => {
				width = canvas.width = window.innerWidth;
				height = canvas.height = window.innerHeight;
				initGrid();
			});

			// Mouse gravity source tracking
			let mouseX = 0;
			let mouseY = 0;
			let mouseActive = false;

			overlay.addEventListener('mousemove', (e) => {
				mouseX = e.clientX;
				mouseY = e.clientY;
				mouseActive = true;
			});

			overlay.addEventListener('mouseleave', () => {
				mouseActive = false;
			});

			overlay.addEventListener('mousedown', (e) => {
				mouseX = e.clientX;
				mouseY = e.clientY;
				mouseActive = true;
			});

			// Touch support for mobile devices
			overlay.addEventListener('touchmove', (e) => {
				if (e.touches.length > 0) {
					mouseX = e.touches[0].clientX;
					mouseY = e.touches[0].clientY;
					mouseActive = true;
				}
			});
			overlay.addEventListener('touchend', () => {
				mouseActive = false;
			});

			// Orbit time accumulator
			let t = 0;
			const baseOrbitRadius = 38;

			// Animation loop
			function animate() {
				ctx.fillStyle = '#000000';
				ctx.fillRect(0, 0, width, height);

				const cx = width / 2;
				const cy = height / 2;

				t += 1;
				
				// Black holes rotation positions
				const currentRadius = baseOrbitRadius * (0.85 + 0.15 * Math.sin(t * 0.003));
				const bh1X = cx + currentRadius * Math.cos(omega * t);
				const bh1Y = cy + currentRadius * Math.sin(omega * t);
				const bh2X = cx - currentRadius * Math.cos(omega * t);
				const bh2Y = cy - currentRadius * Math.sin(omega * t);

				// Draw grid
				gridPoints.forEach(p => {
					// Distances
					const dx = p.origX - cx;
					const dy = p.origY - cy;
					const dist = Math.sqrt(dx * dx + dy * dy);
					const d = Math.max(dist, 10);
					const theta = Math.atan2(dy, dx);

					// Spiral quadrupole wave front phase
					const phase = 2 * theta - 2 * omega * (t - d / c);
					const amp = (A0 * 150) / (d + 120);

					// Dynamic gravitational stretching
					const offsetStrength = amp * Math.cos(phase);
					let offsetX = offsetStrength * Math.cos(theta) * 0.45;
					let offsetY = offsetStrength * Math.sin(theta) * 0.45;

					// Add mouse attraction local warp (stretching the metric towards the cursor)
					if (mouseActive && mouseMass > 0) {
						const mdx = mouseX - p.origX;
						const mdy = mouseY - p.origY;
						const mdist = Math.sqrt(mdx * mdx + mdy * mdy);
						if (mdist < 240) {
							// Einstein/引力透鏡 metric warp offset towards mouse
							const pull = (240 - mdist) / 240 * mouseMass;
							offsetX += (mdx / (mdist + 1)) * pull;
							offsetY += (mdy / (mdist + 1)) * pull;
						}
					}

					const renderX = p.origX + offsetX;
					const renderY = p.origY + offsetY;

					// Render opacity
					const alpha = Math.max(0.08, 0.72 - (d / (width * 0.65)));

					// Steel gray / plaster particles matching the updated site aesthetics
					ctx.fillStyle = `rgba(192, 196, 204, ${alpha})`;
					ctx.beginPath();
					const r = d < 120 ? 1.8 : 1.1;
					ctx.arc(renderX, renderY, r, 0, Math.PI * 2);
					ctx.fill();
				});

				// Draw Binary Black Holes
				ctx.shadowBlur = 10;
				ctx.shadowColor = 'rgba(255, 255, 255, 0.2)';
				ctx.fillStyle = 'rgba(0, 0, 0, 1)';
				ctx.strokeStyle = 'rgba(255, 255, 255, 0.5)';
				ctx.lineWidth = 1;

				// BH 1
				ctx.beginPath();
				ctx.arc(bh1X, bh1Y, bhMass, 0, Math.PI * 2);
				ctx.fill();
				ctx.stroke();

				// BH 2
				ctx.beginPath();
				ctx.arc(bh2X, bh2Y, bhMass, 0, Math.PI * 2);
				ctx.fill();
				ctx.stroke();

				// Reset shadow blur
				ctx.shadowBlur = 0;

				// Draw mouse gravity attractor if active
				if (mouseActive && mouseMass > 0) {
					ctx.beginPath();
					ctx.arc(mouseX, mouseY, 3, 0, Math.PI * 2);
					ctx.fillStyle = 'rgba(255, 255, 255, 0.4)';
					ctx.fill();
				}

				requestAnimationFrame(animate);
			}

			animate();
		</script>
	</body>
</html>
