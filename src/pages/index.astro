---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
---

<Layout title="首頁 HOME">
	<div class="home-hero">
		<!-- Refined Minimalist Typography in grayer, elegant colors -->
		<h1 class="home-title">WONGLING</h1>
		<p class="home-subtitle">Research on Parapsychology and Unexplained Phenomena</p>
	</div>
</Layout>

<style>
	.home-hero {
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		height: 52vh; /* Centered in standard viewport under header without causing overflow */
		text-align: center;
		box-sizing: border-box;
		animation: fadeIn 2.5s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.home-title {
		font-family: var(--font-sans);
		font-size: 2.4rem; /* Refined, smaller size */
		font-weight: 400;
		letter-spacing: 10px;
		margin: 0;
		color: rgba(255, 255, 255, 0.72); /* Understated, darker steel gray */
		text-transform: uppercase;
		text-shadow: 0 0 20px rgba(255, 255, 255, 0.03);
	}

	.home-subtitle {
		font-family: var(--font-serif);
		font-size: 0.95rem; /* Understated, elegant size */
		font-weight: 300;
		letter-spacing: 2px;
		color: rgba(255, 255, 255, 0.42); /* Softer gray color */
		margin-top: 1.2rem;
		margin-bottom: 0;
	}

	@keyframes fadeIn {
		from { opacity: 0; transform: scale(0.98) translateY(6px); }
		to { opacity: 1; transform: scale(1) translateY(0); }
	}

	/* Hide footer on home page for pure splash style */
	:global(body:has(.home-hero) footer) {
		display: none !important;
	}

	@media (max-width: 768px) {
		.home-hero {
			height: 48vh;
		}
		.home-title {
			font-size: 1.8rem;
			letter-spacing: 6px;
		}
		.home-subtitle {
			font-size: 0.8rem;
			letter-spacing: 1px;
			padding: 0 1.5rem;
			line-height: 1.5;
		}
	}
</style>
