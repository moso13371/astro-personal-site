---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
---

<Layout title="首頁 HOME">
	<div class="home-hero">
		<!-- Centered Minimalist Chinese Subtitle only -->
		<h1 class="home-subtitle">超心理學與未明現象調查研究</h1>
	</div>
</Layout>

<style>
	.home-hero {
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		height: 52vh; /* Centered in standard viewport under header without causing overflow */
		text-align: center;
		box-sizing: border-box;
		animation: fadeIn 2.5s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.home-subtitle {
		font-family: var(--font-serif);
		font-size: 1.35rem; /* Elegant centerpiece size */
		font-weight: 300;
		letter-spacing: 6px;
		color: #ffffff;
		margin: 0;
		text-shadow: 0 0 35px rgba(255, 255, 255, 0.15);
	}

	@keyframes fadeIn {
		from { opacity: 0; transform: scale(0.98) translateY(6px); }
		to { opacity: 1; transform: scale(1) translateY(0); }
	}

	/* Hide footer on home page for pure splash style */
	:global(body:has(.home-hero) footer) {
		display: none !important;
	}

	@media (max-width: 768px) {
		.home-hero {
			height: 48vh;
		}
		.home-subtitle {
			font-size: 1.05rem;
			letter-spacing: 4px;
			padding: 0 1rem;
			line-height: 1.6;
		}
	}
</style>
