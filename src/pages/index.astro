---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
---

<Layout title="首頁 HOME">
	<div class="home-hero">
		<!-- Refined Minimalist Typography in grayer, elegant colors -->
		<h1 class="home-title">WONGLING</h1>
		
		<!-- 零位移原地切換副標題容器 (Zero-Displacement Subtitle Wrapper) -->
		<div class="subtitles-wrapper">
			<!-- 正常維度副標題 (Normal Phase Subtitles - Centered) -->
			<div class="normal-subtitle-group">
				<p class="subtitle-zh">往櫺 &mdash; 臺灣超心理學與未明現象研究調查員</p>
				<p class="subtitle-en">Taiwanese researcher of parapsychology and unexplained phenomena</p>
			</div>

			<!-- 切換維度副標題 (Shifted Phase Subtitles - Centered) -->
			<div class="shifted-subtitle-group">
				<p class="subtitle-zh">迷幻、異常感知、聲波系統與靈性觀察研究</p>
				<p class="subtitle-en">Psychedelic research, sound systems, and spiritual observation</p>
			</div>
		</div>

		<!-- 沉浸式控制按鈕 (Environment Controls - Brackets Removed) -->
		<div class="home-controls">
			<button id="sound-btn" class="control-btn" aria-label="Toggle binaural ambient sounds">SOUND: OFF</button>
			<button id="phase-btn" class="control-btn" aria-label="Shift dimension phase">PHASE: BASELINE</button>
		</div>

		<!-- 說明按鈕 (Info Button Below Controls - Brackets Removed) -->
		<div class="info-controls">
			<button id="info-btn" class="info-link-btn" aria-label="View binaural beats protocol description">BINAURAL BEATS PROTOCOL</button>
		</div>
	</div>
</Layout>

<script>
	document.addEventListener('DOMContentLoaded', () => {
		const soundBtn = document.getElementById('sound-btn');
		const phaseBtn = document.getElementById('phase-btn');
		const infoBtn = document.getElementById('info-btn');
		const infoModal = document.getElementById('info-modal');
		const closeModalBtn = document.getElementById('close-modal-btn');

		if (soundBtn) {
			soundBtn.addEventListener('click', () => {
				if ((window as any).toggleBinauralSound) {
					const isActive = (window as any).toggleBinauralSound();
					soundBtn.textContent = isActive ? 'SOUND: ON' : 'SOUND: OFF';
					if (isActive) {
						soundBtn.classList.add('btn-active');
					} else {
						soundBtn.classList.remove('btn-active');
					}
				}
			});
		}

		if (phaseBtn) {
			phaseBtn.addEventListener('click', () => {
				const isShifted = document.body.classList.toggle('phase-shifted');
				(window as any).isPhaseShifted = isShifted;
				phaseBtn.textContent = isShifted ? 'PHASE: ALTERED' : 'PHASE: BASELINE';
				if (isShifted) {
					phaseBtn.classList.add('btn-active');
				} else {
					phaseBtn.classList.remove('btn-active');
				}
				// Dispatch custom phase-change event so audio adjusts immediately
				window.dispatchEvent(new CustomEvent('phase-change', { detail: { isShifted } }));
			});
		}

		// Modal Controls (Targets layout portal)
		if (infoBtn && infoModal && closeModalBtn) {
			infoBtn.addEventListener('click', () => {
				infoModal.classList.add('show');
				infoModal.setAttribute('aria-hidden', 'false');
				document.body.style.overflow = 'hidden'; // Lock body scroll when open
			});

			closeModalBtn.addEventListener('click', () => {
				infoModal.classList.remove('show');
				infoModal.setAttribute('aria-hidden', 'true');
				document.body.style.overflow = ''; // Unlock body scroll when closed
			});

			// Close on clicking overlay background
			infoModal.addEventListener('click', (e) => {
				if (e.target === infoModal) {
					infoModal.classList.remove('show');
					infoModal.setAttribute('aria-hidden', 'true');
					document.body.style.overflow = ''; // Unlock
				}
			});
		}
	});
</script>

<style>
	.home-hero {
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: stretch;
		height: 58vh;
		width: 100%;
		max-width: 580px;
		margin-left: auto;
		margin-right: auto;
		padding: 0 2.2rem;
		box-sizing: border-box;
		animation: fadeIn 2.5s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.home-title {
		font-family: var(--font-sans);
		font-size: 2.3rem;
		font-weight: 300;
		letter-spacing: 18px;
		margin: 0;
		margin-right: -18px; /* Negative margin offsets right-side letter-spacing for perfect centering */
		color: var(--text-color);
		text-transform: uppercase;
		text-shadow: 0 0 30px rgba(200, 202, 208, 0.05);
		text-align: center;
		align-self: center;
		animation: fadeInTitle 2.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
		transition: color 1s ease;
	}

	/* Zero-Displacement Wrapper - stable height for centered subtitles */
	.subtitles-wrapper {
		position: relative;
		width: 100%;
		height: 3.5rem;
		margin-top: 2.2rem;
	}

	.normal-subtitle-group,
	.shifted-subtitle-group {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
		align-items: center;
		text-align: center;
		transition: opacity 0.6s ease-in-out;
	}

	.normal-subtitle-group {
		opacity: 1;
		pointer-events: auto;
	}

	.shifted-subtitle-group {
		opacity: 0;
		pointer-events: none;
	}

	.subtitle-zh {
		font-family: var(--font-sans);
		font-size: 0.88rem;
		font-weight: 300;
		letter-spacing: 4px;
		margin-right: -4px; /* Offset letter-spacing */
		color: var(--text-color);
		margin-top: 0;
		margin-bottom: 0;
		text-transform: uppercase;
		transition: color 1s ease;
	}

	.subtitle-en {
		font-family: monospace;
		font-style: normal;
		font-size: 0.76rem;
		font-weight: 300;
		letter-spacing: 1px;
		color: var(--text-color);
		opacity: 0.85;
		margin: 0;
		transition: color 1s ease;
	}

	/* Environment Controls - Positioned lower for balance */
	.home-controls {
		display: flex;
		gap: 1.5rem;
		margin-top: 7.5rem;
		align-self: center;
		animation: fadeInControls 3.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
		z-index: 10;
	}

	.control-btn {
		background: none;
		border: none;
		color: var(--text-color);
		font-family: var(--font-serif);
		font-size: 0.72rem;
		letter-spacing: 2px;
		cursor: pointer;
		padding: 0.4rem 0.8rem;
		border: 1px solid rgba(200, 202, 208, 0.16);
		border-radius: 4px;
		transition: all 0.4s ease;
		background-color: rgba(255, 255, 255, 0.002);
	}

	.control-btn:hover {
		color: var(--accent-hover);
		border-color: rgba(255, 255, 255, 0.6);
		text-shadow: 0 0 10px rgba(255, 255, 255, 0.08);
	}

	.control-btn.btn-active {
		color: var(--accent-hover);
		border-color: rgba(255, 255, 255, 0.6);
		background-color: rgba(255, 255, 255, 0.015);
	}

	/* Info controls button below sound toggles */
	.info-controls {
		margin-top: 1.6rem;
		align-self: center;
		animation: fadeInControls 3.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
		z-index: 10;
	}

	.info-link-btn {
		background: none;
		border: none;
		color: var(--text-color);
		opacity: 0.75;
		font-family: monospace;
		font-size: 0.65rem;
		letter-spacing: 1px;
		cursor: pointer;
		padding: 0.3rem 0.6rem;
		transition: all 0.4s ease;
	}

	.info-link-btn:hover {
		color: var(--accent-hover);
		opacity: 1;
		text-shadow: 0 0 8px rgba(255, 255, 255, 0.08);
	}

	/* Phase shifted theme styling - Centered Violet alignments */
	:global(body.phase-shifted) .home-title {
		color: rgba(216, 180, 254, 0.95) !important;
		text-shadow: -1.5px 0 rgba(239, 68, 68, 0.6), 1.5px 0 rgba(16, 185, 129, 0.6), 0 0 35px rgba(168, 85, 247, 0.25) !important;
	}

	:global(body.phase-shifted) .normal-subtitle-group {
		opacity: 0;
		pointer-events: none;
	}

	:global(body.phase-shifted) .shifted-subtitle-group {
		opacity: 1;
		pointer-events: auto;
	}

	:global(body.phase-shifted) .subtitle-zh {
		color: rgba(216, 180, 254, 0.95) !important;
	}

	:global(body.phase-shifted) .subtitle-en {
		color: rgba(216, 180, 254, 0.95) !important;
		opacity: 0.85;
	}

	:global(body.phase-shifted) .control-btn {
		color: rgba(216, 180, 254, 0.95);
		border-color: rgba(168, 85, 247, 0.32);
	}

	:global(body.phase-shifted) .control-btn:hover {
		color: #ffffff;
		border-color: rgba(192, 132, 252, 0.8);
		text-shadow: 0 0 10px rgba(168, 85, 247, 0.25);
	}

	:global(body.phase-shifted) .control-btn.btn-active {
		color: #ffffff;
		border-color: rgba(192, 132, 252, 0.8);
		background-color: rgba(168, 85, 247, 0.03);
	}

	:global(body.phase-shifted) .info-link-btn {
		color: rgba(216, 180, 254, 0.95);
		opacity: 0.8;
	}

	:global(body.phase-shifted) .info-link-btn:hover {
		color: #ffffff;
		opacity: 1;
		text-shadow: 0 0 8px rgba(168, 85, 247, 0.15);
	}

	/* Modal Window Global Portal styling - Centered relative to screen viewport */
	:global(.modal-overlay) {
		position: fixed;
		top: 0;
		left: 0;
		width: 100vw;
		height: 100vh;
		background-color: rgba(6, 6, 6, 0.82);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		display: flex;
		justify-content: center;
		align-items: center;
		z-index: 99999; /* Higher priority than navigation dropdown */
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1);
	}

	:global(.modal-overlay.show) {
		opacity: 1;
		pointer-events: auto;
	}

	:global(.modal-content) {
		background-color: rgba(14, 14, 14, 0.88);
		border: 1px solid rgba(255, 255, 255, 0.06);
		border-radius: 8px;
		width: 90%;
		max-width: 460px;
		padding: 2.2rem;
		box-sizing: border-box;
		box-shadow: 0 20px 50px rgba(0, 0, 0, 0.65);
		transform: scale(0.96);
		transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	:global(.modal-overlay.show .modal-content) {
		transform: scale(1);
	}

	:global(.modal-title) {
		font-family: var(--font-sans);
		font-size: 1.1rem;
		font-weight: 350;
		letter-spacing: 3px;
		color: rgba(255, 255, 255, 0.72);
		margin: 0;
		text-align: center;
		line-height: 1.4;
	}

	:global(.modal-sub) {
		font-family: monospace;
		font-size: 0.7rem;
		font-weight: 300;
		letter-spacing: 1px;
		color: rgba(255, 255, 255, 0.28);
	}

	:global(.modal-body) {
		display: flex;
		flex-direction: column;
		gap: 1.2rem;
		max-height: 55vh;
		overflow-y: auto;
		text-align: left;
		padding-right: 6px;
	}

	:global(.modal-body::-webkit-scrollbar) {
		width: 3px;
	}
	:global(.modal-body::-webkit-scrollbar-track) {
		background: rgba(255, 255, 255, 0.01);
	}
	:global(.modal-body::-webkit-scrollbar-thumb) {
		background: rgba(255, 255, 255, 0.08);
		border-radius: 2px;
	}

	:global(.intro-paragraph) {
		font-family: var(--font-serif);
		font-size: 0.82rem;
		line-height: 1.6;
		color: rgba(255, 255, 255, 0.65) !important;
		border-left: 2px solid rgba(255, 255, 255, 0.15);
		padding-left: 10px;
		margin: 0 0 0.5rem 0;
	}

	:global(body.phase-shifted .intro-paragraph) {
		border-left-color: rgba(168, 85, 247, 0.35);
	}

	:global(.modal-body section) {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}

	:global(.modal-body h3) {
		font-family: var(--font-sans);
		font-size: 0.76rem;
		font-weight: 400;
		letter-spacing: 1px;
		color: rgba(255, 255, 255, 0.55);
		margin: 0;
		border-bottom: 1px solid rgba(255, 255, 255, 0.04);
		padding-bottom: 4px;
	}

	:global(.modal-body p), :global(.modal-body li) {
		font-family: var(--font-serif);
		font-size: 0.8rem;
		line-height: 1.6;
		color: rgba(255, 255, 255, 0.42);
		margin: 0;
	}

	:global(.modal-body ul) {
		margin: 0;
		padding-left: 1.2rem;
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}

	:global(.recommend-text) {
		color: rgba(255, 255, 255, 0.6) !important;
		font-style: italic;
	}

	:global(.footer-note-section) {
		margin-top: 0.5rem;
		border-top: 1px solid rgba(255, 255, 255, 0.04);
		padding-top: 0.8rem;
	}

	:global(body.phase-shifted .footer-note-section) {
		border-top-color: rgba(168, 85, 247, 0.08);
	}

	:global(.modal-footer-note) {
		font-size: 0.76rem !important;
		color: rgba(255, 255, 255, 0.32) !important;
		text-align: center;
	}

	:global(body.phase-shifted .modal-footer-note) {
		color: rgba(192, 132, 252, 0.5) !important;
	}

	:global(.modal-close-btn) {
		background: none;
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 4px;
		color: rgba(255, 255, 255, 0.45);
		font-family: monospace;
		font-size: 0.72rem;
		letter-spacing: 2px;
		padding: 0.5rem 1rem;
		cursor: pointer;
		transition: all 0.4s ease;
		align-self: center;
		margin-top: 0.5rem;
	}

	:global(.modal-close-btn:hover) {
		color: rgba(255, 255, 255, 0.8);
		border-color: rgba(255, 255, 255, 0.3);
		background-color: rgba(255, 255, 255, 0.02);
	}

	/* Phase shifted modal styling */
	:global(body.phase-shifted .modal-content) {
		border-color: rgba(168, 85, 247, 0.15);
		box-shadow: 0 20px 50px rgba(168, 85, 247, 0.05);
	}
	:global(body.phase-shifted .modal-title) {
		color: rgba(192, 132, 252, 0.82);
	}
	:global(body.phase-shifted .modal-body h3) {
		color: rgba(192, 132, 252, 0.65);
		border-bottom-color: rgba(168, 85, 247, 0.08);
	}
	:global(body.phase-shifted .modal-close-btn) {
		border-color: rgba(168, 85, 247, 0.25);
		color: rgba(192, 132, 252, 0.7);
	}
	:global(body.phase-shifted .modal-close-btn:hover) {
		color: rgba(192, 132, 252, 0.95);
		border-color: rgba(168, 85, 247, 0.55);
		background-color: rgba(168, 85, 247, 0.03);
	}

	/* Staggered load animations */
	@keyframes fadeInTitle {
		0% {
			opacity: 0;
		}
		100% {
			opacity: 1;
		}
	}

	@keyframes fadeInControls {
		0% {
			opacity: 0;
			transform: translateY(2px);
		}
		60% {
			opacity: 0;
		}
		100% {
			opacity: 1;
			transform: translateY(0);
		}
	}

	/* Hide footer on home page for pure splash style */
	:global(body:has(.home-hero) footer) {
		display: none !important;
	}

	@media (max-width: 768px) {
		/* Lock vertical scrollable container overflow on mobile */
		:global(body:has(.home-hero)) {
			overflow: hidden !important;
		}
		
		/* Reduce header margins to prevent mobile overflow */
		:global(body:has(.home-hero) header) {
			margin-bottom: 2rem !important;
			padding-top: 1.8rem !important;
		}

		.home-hero {
			height: auto;
			min-height: 48vh;
			padding: 0 1.5rem;
		}
		.home-title {
			font-size: 1.8rem;
			letter-spacing: 13px;
			margin-right: -13px; /* Offset mobile letter spacing */
		}
		.subtitles-wrapper {
			height: 3.8rem;
		}
		.subtitle-zh {
			font-size: 0.8rem;
			letter-spacing: 2px;
			margin-right: -2px; /* Offset mobile letter spacing */
		}
		.subtitle-en {
			font-size: 0.72rem;
			letter-spacing: 0.5px;
		}
		.home-controls {
			margin-top: 3.5rem; /* Reduced to pull buttons upwards and prevent mobile scrolling */
			gap: 1rem;
		}
		.control-btn {
			font-size: 0.68rem;
			padding: 0.35rem 0.7rem;
		}
		.info-controls {
			margin-top: 1.2rem; /* Reduced padding */
		}
	}
</style>
