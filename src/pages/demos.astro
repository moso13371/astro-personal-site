---
// src/pages/demos.astro
---

<!doctype html>
<html lang="zh-TW">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>粒子物理與意識共振實驗室 | WONGLING</title>
		<!-- Google Fonts: Inter and Noto Serif TC -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&family=Noto+Serif+TC:wght@300;400;600&display=swap" rel="stylesheet">
		<style>
			body, html {
				margin: 0;
				padding: 0;
				width: 100%;
				height: 100%;
				overflow: hidden;
				background-color: #000000;
				font-family: 'Inter', 'Noto Serif TC', sans-serif;
				color: #ffffff;
				user-select: none;
			}

			#lab-canvas {
				display: block;
				width: 100vw;
				height: 100vh;
				z-index: 1;
				position: absolute;
				top: 0;
				left: 0;
			}

			.interactive-layer {
				position: absolute;
				z-index: 5;
				width: 100%;
				height: 100%;
				top: 0;
				left: 0;
				cursor: pointer;
			}

			.overlay {
				position: absolute;
				z-index: 10;
				pointer-events: none;
				width: 100%;
				height: 100%;
				display: flex;
				flex-direction: column;
				justify-content: space-between;
				box-sizing: border-box;
				padding: 2rem;
			}

			/* Navigation & Tabs UI */
			.header-area {
				display: flex;
				justify-content: space-between;
				align-items: flex-start;
				width: 100%;
			}

			.back-btn {
				pointer-events: auto;
				color: rgba(255, 255, 255, 0.5);
				text-decoration: none;
				font-size: 0.85rem;
				letter-spacing: 2px;
				text-transform: uppercase;
				transition: all 0.4s ease;
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
				border: 1px solid rgba(255, 255, 255, 0.1);
				padding: 8px 16px;
				background: rgba(10, 10, 10, 0.6);
				backdrop-filter: blur(10px);
				-webkit-backdrop-filter: blur(10px);
			}

			.back-btn:hover {
				color: #ffffff;
				border-color: #ffffff;
				transform: translateX(-3px);
			}

			/* Sidebar / Left Tab Selection */
			.tabs-container {
				pointer-events: auto;
				position: absolute;
				top: 6.5rem;
				left: 2rem;
				display: flex;
				flex-direction: column;
				gap: 0.5rem;
				background: rgba(15, 16, 18, 0.65);
				border: 1px solid rgba(255, 255, 255, 0.05);
				backdrop-filter: blur(15px);
				-webkit-backdrop-filter: blur(15px);
				padding: 0.75rem;
				width: 220px;
				z-index: 20;
			}

			.tab-button {
				background: none;
				border: 1px solid transparent;
				color: rgba(255, 255, 255, 0.4);
				padding: 12px 16px;
				text-align: left;
				font-size: 0.75rem;
				font-weight: 400;
				letter-spacing: 2px;
				cursor: pointer;
				transition: all 0.4s ease;
				text-transform: uppercase;
				width: 100%;
				box-sizing: border-box;
			}

			.tab-button:hover {
				color: #ffffff;
				background: rgba(255, 255, 255, 0.03);
			}

			.tab-button.active {
				color: #ffffff;
				border-color: rgba(255, 255, 255, 0.15);
				background: rgba(255, 255, 255, 0.05);
				font-weight: 500;
			}

			/* Controls Box */
			.control-box {
				pointer-events: auto;
				position: absolute;
				top: 2rem;
				right: 2rem;
				z-index: 20;
				width: 260px;
				background: rgba(15, 16, 18, 0.75);
				border: 1px solid rgba(255, 255, 255, 0.08);
				backdrop-filter: blur(15px);
				-webkit-backdrop-filter: blur(15px);
				padding: 1.5rem;
				display: flex;
				flex-direction: column;
				gap: 1.2rem;
			}

			.control-box-title {
				font-size: 0.8rem;
				font-weight: 500;
				margin: 0;
				letter-spacing: 2px;
				color: #c0c4cc;
				border-bottom: 1px solid rgba(255, 255, 255, 0.1);
				padding-bottom: 0.5rem;
			}

			.control-group {
				display: flex;
				flex-direction: column;
				gap: 0.4rem;
			}

			.control-group label {
				font-size: 0.72rem;
				color: rgba(255, 255, 255, 0.5);
				letter-spacing: 1px;
				display: flex;
				justify-content: space-between;
			}

			.control-group label span {
				color: #ffffff;
				font-weight: 500;
			}

			.control-group input[type="range"] {
				-webkit-appearance: none;
				width: 100%;
				height: 2px;
				background: rgba(255, 255, 255, 0.15);
				outline: none;
				margin: 8px 0;
			}

			.control-group input[type="range"]::-webkit-slider-thumb {
				-webkit-appearance: none;
				appearance: none;
				width: 8px;
				height: 8px;
				border-radius: 50%;
				background: #ffffff;
				cursor: pointer;
				transition: transform 0.1s ease;
			}

			.control-group input[type="range"]::-webkit-slider-thumb:hover {
				transform: scale(1.4);
			}

			.control-select {
				background: rgba(10, 10, 10, 0.8);
				border: 1px solid rgba(255, 255, 255, 0.15);
				color: #ffffff;
				font-size: 0.72rem;
				padding: 6px;
				outline: none;
				font-family: inherit;
				cursor: pointer;
				letter-spacing: 1px;
			}

			.control-select option {
				background: #111215;
				color: #ffffff;
			}

			/* Detailed Info Panel */
			.info-panel {
				pointer-events: auto;
				align-self: flex-start;
				text-align: left;
				background: rgba(10, 10, 10, 0.7);
				border: 1px solid rgba(255, 255, 255, 0.08);
				backdrop-filter: blur(15px);
				-webkit-backdrop-filter: blur(15px);
				max-width: 480px;
				max-height: 52vh;
				margin-top: auto;
				padding: 1.8rem;
				box-sizing: border-box;
				display: flex;
				flex-direction: column;
				z-index: 20;
			}

			.info-title {
				font-family: 'Noto Serif TC', serif;
				font-size: 1.15rem;
				font-weight: 500;
				letter-spacing: 2px;
				margin-top: 0;
				margin-bottom: 0.8rem;
				color: #ffffff;
				border-bottom: 1px solid rgba(255, 255, 255, 0.1);
				padding-bottom: 0.5rem;
			}

			.info-body {
				overflow-y: auto;
				padding-right: 0.5rem;
				display: flex;
				flex-direction: column;
				gap: 1rem;
			}

			/* Scrollbar Styling */
			.info-body::-webkit-scrollbar {
				width: 3px;
			}
			.info-body::-webkit-scrollbar-track {
				background: rgba(255, 255, 255, 0.02);
			}
			.info-body::-webkit-scrollbar-thumb {
				background: rgba(255, 255, 255, 0.15);
			}

			.info-section-title {
				font-size: 0.78rem;
				font-weight: 600;
				color: #c0c4cc;
				margin-bottom: 0.3rem;
				letter-spacing: 1px;
				text-transform: uppercase;
			}

			.info-text {
				font-size: 0.75rem;
				color: rgba(255, 255, 255, 0.55);
				line-height: 1.7;
				letter-spacing: 0.8px;
				margin: 0;
			}

			.info-references {
				border-top: 1px dashed rgba(255, 255, 255, 0.1);
				padding-top: 0.6rem;
				margin-top: 0.4rem;
			}

			.reference-item {
				font-size: 0.7rem;
				color: rgba(255, 255, 255, 0.4);
				margin: 0 0 0.3rem 0;
				line-height: 1.5;
			}

			/* Responsive styling */
			@media (max-width: 768px) {
				.overlay {
					padding: 1rem;
				}
				.header-area {
					flex-direction: column;
					gap: 1rem;
				}
				.tabs-container {
					position: relative;
					top: auto;
					left: auto;
					flex-direction: row;
					width: 100%;
					overflow-x: auto;
					margin-top: 0.5rem;
					padding: 0.5rem;
				}
				.tab-button {
					padding: 8px 12px;
					font-size: 0.7rem;
					white-space: nowrap;
					text-align: center;
				}
				.control-box {
					position: relative;
					top: auto;
					right: auto;
					width: 100%;
					box-sizing: border-box;
					margin-top: 1rem;
				}
				.info-panel {
					display: none; /* Hide bottom panel on mobile */
				}
			}
		</style>
	</head>
	<body>
		<canvas id="lab-canvas"></canvas>

		<!-- Capture cursor interactions -->
		<div id="interactive-overlay" class="interactive-layer"></div>

		<!-- UI Overlay -->
		<div class="overlay">
			<div class="header-area">
				<a href="/" class="back-btn">
					&larr; 返回官網
				</a>
			</div>
			
			<!-- Sidebar selection tabs -->
			<div class="tabs-container">
				<button class="tab-button active" data-tab="gravity">重力波 GRAVITY</button>
				<button class="tab-button" data-tab="bowl">頌缽聲波 CYMATICS</button>
				<button class="tab-button" data-tab="drum">框鼓共振 RESONANCE</button>
				<button class="tab-button" data-tab="dmt">DMT 意識流動</button>
			</div>
			
			<!-- Academic & Interactive Info Panel -->
			<div class="info-panel">
				<h2 id="display-title" class="info-title">重力波與時空幾何演示</h2>
				<div class="info-body">
					<div>
						<div class="info-section-title">科學探索 (Scientific Focus)</div>
						<p id="desc-focus" class="info-text"></p>
					</div>
					<div>
						<div class="info-section-title">物理共振原理 (Physics Principles)</div>
						<p id="desc-principle" class="info-text"></p>
					</div>
					<div>
						<div class="info-section-title">互動操作指南 (Interaction Guide)</div>
						<p id="desc-guide" class="info-text"></p>
					</div>
					<div>
						<div class="info-section-title">演示推薦理由 (Why Recommend)</div>
						<p id="desc-why" class="info-text"></p>
					</div>
					<div class="info-references">
						<div class="info-section-title">權威科學文獻 (References)</div>
						<div id="desc-references"></div>
					</div>
				</div>
			</div>
		</div>

		<!-- Control Box containing dynamic sliders -->
		<div class="control-box">
			<h3 class="control-box-title">控制面板 CONTROLS</h3>
			
			<!-- Gravity Wave Sliders -->
			<div id="sliders-gravity" class="slider-group">
				<div class="control-group">
					<label>繞行頻率 (Speed): <span id="val-g-speed">0.035</span></label>
					<input type="range" id="param-g-speed" min="0.005" max="0.10" step="0.005" value="0.035">
				</div>
				<div class="control-group">
					<label>波形振幅 (Amplitude): <span id="val-g-amp">30</span></label>
					<input type="range" id="param-g-amp" min="5" max="80" step="5" value="30">
				</div>
				<div class="control-group">
					<label>波形波速 (Wave Speed): <span id="val-g-c">7.5</span></label>
					<input type="range" id="param-g-c" min="4.0" max="15.0" step="0.5" value="7.5">
				</div>
				<div class="control-group">
					<label>引力扭曲 (Mouse Gravity): <span id="val-g-mouse">30</span></label>
					<input type="range" id="param-g-mouse" min="0" max="80" step="5" value="30">
				</div>
			</div>

			<!-- Singing Bowl Sliders -->
			<div id="sliders-bowl" class="slider-group" style="display: none;">
				<div class="control-group">
					<label>傳播方向 (Direction):</label>
					<select id="param-b-dir" class="control-select">
						<option value="both">內外全向擴散 (Omni)</option>
						<option value="out">向外擴散 (Outward)</option>
						<option value="in">向內共鳴 (Inward)</option>
					</select>
				</div>
				<div class="control-group">
					<label>頌缽尺寸 (Bowl Size):</label>
					<select id="param-b-size" class="control-select">
						<option value="large">大型低音缽 (Large / Low)</option>
						<option value="small">小型高音缽 (Small / High)</option>
					</select>
				</div>
				<div class="control-group">
					<label>激發方式 (Action):</label>
					<select id="param-b-action" class="control-select">
						<option value="rub">磨缽共振 (Continuous Rub)</option>
						<option value="strike">敲擊瞬態 (Transient Hit)</option>
					</select>
				</div>
				<div class="control-group">
					<label>聲波頻率 (Frequency): <span id="val-b-freq">0.05</span></label>
					<input type="range" id="param-b-freq" min="0.02" max="0.10" step="0.01" value="0.05">
				</div>
				<div class="control-group">
					<label>聲波能量 (Energy): <span id="val-b-amp">12</span></label>
					<input type="range" id="param-b-amp" min="2" max="30" step="1" value="12">
				</div>
			</div>

			<!-- Frame Drum Sliders -->
			<div id="sliders-drum" class="slider-group" style="display: none;">
				<div class="control-group">
					<label>擊鼓力道 (Strike Power): <span id="val-d-power">25</span></label>
					<input type="range" id="param-d-power" min="5" max="50" step="5" value="25">
				</div>
				<div class="control-group">
					<label>鼓皮張力 (Tension): <span id="val-d-tension">0.04</span></label>
					<input type="range" id="param-d-tension" min="0.01" max="0.10" step="0.01" value="0.04">
				</div>
				<div class="control-group">
					<label>振相衰減 (Decay): <span id="val-d-decay">0.015</span></label>
					<input type="range" id="param-d-decay" min="0.005" max="0.05" step="0.005" value="0.015">
				</div>
				<div class="control-group">
					<label>共振模態 (Harmonic Mode): <span id="val-d-mode">1</span></label>
					<input type="range" id="param-d-mode" min="0" max="3" step="1" value="1">
				</div>
			</div>

			<!-- DMT Sliders -->
			<div id="sliders-dmt" class="slider-group" style="display: none;">
				<div class="control-group">
					<label>幾何對稱 (Symmetry Fold): <span id="val-dm-sym">6</span></label>
					<input type="range" id="param-dm-sym" min="3" max="12" step="1" value="6">
				</div>
				<div class="control-group">
					<label>流動速度 (Drift Speed): <span id="val-dm-speed">0.02</span></label>
					<input type="range" id="param-dm-speed" min="0.005" max="0.06" step="0.005" value="0.02">
				</div>
				<div class="control-group">
					<label>維度複雜度 (Complexity): <span id="val-dm-comp">3.0</span></label>
					<input type="range" id="param-dm-comp" min="1.0" max="6.0" step="0.2" value="3.0">
				</div>
				<div class="control-group">
					<label>幻覺輝光 (Glow Intensity): <span id="val-dm-glow">0.45</span></label>
					<input type="range" id="param-dm-glow" min="0.1" max="0.9" step="0.05" value="0.45">
				</div>
			</div>
		</div>

		<script>
			const canvas = document.getElementById('lab-canvas');
			const ctx = canvas.getContext('2d');
			const overlay = document.getElementById('interactive-overlay');

			let width = canvas.width = window.innerWidth;
			let height = canvas.height = window.innerHeight;

			// Simulation states
			let currentTab = 'gravity';
			let t = 0;

			// Cursor Coordinates
			let mouseX = width / 2;
			let mouseY = height / 2;
			let mouseActive = false;

			// Academic descriptions
			const tabDescriptions = {
				gravity: {
					title: "重力波與時空幾何演示",
					focus: "本模型模擬大質量天體（如雙黑洞 Coalescing Binary Black Holes）互繞合併時，在二維時空網格中產生的引力輻射（Gravitational Radiation）。",
					principle: "根據愛因斯坦廣義相對論（General Relativity, 1915），大質量天體的加速運動會引發時空度規（Spacetime Metric）的波動。這種波動以光速傳播，導致空間在一個方向拉伸時，在垂直方向壓縮（即四極矩 h+ 與 hx 偏振）。本模擬可視化了螺旋狀傳播的波動如何在空間粒子中引起位移。",
					guide: "調整【繞行頻率】改變雙引力源互繞的速度，進而影響引力波頻率；【波形振幅】調節波幅強度；【波形波速】調節波長傳播延遲。移動滑鼠可以在特定網格點施加滑鼠引力扭曲，模擬局部重力透鏡效應。",
					why: "引力波是極其微弱且抽象的時空漣漪。透過本模型，讀者能將無形的廣義相對論場方程，轉化為直觀的幾何波動知覺，了解質量與時空曲率之間的互動關係。",
					references: [
						"Einstein, A. (1916). Näherungsweise Integration der Feldgleichungen der Gravitation. (廣義相對論場方程近似積分)",
						"Abbott, B. P. et al. (LIGO). (2016). Observation of Gravitational Waves from a Binary Black Hole Merger. PRL. (引力波首次直接觀測實證)"
					]
				},
				bowl: {
					title: "頌缽聲波與聲波粒子傳播演示",
					focus: "本模型模擬頌缽（Singing Bowl）發出聲響時，聲學彈性聲波（Acoustic Soundwaves）在缽體周圍空氣及內部空間的「壓縮與膨脹（縱波/壓縮波）」傳播形態。",
					principle: "頌缽發聲是缽壁物理機械振動推擠周圍空氣的過程。當我們敲擊或摩擦缽緣時，缽壁的彈性形變會引發空氣分子的疏密變化。由於聲波屬於縱波（Longitudinal Wave），粒子在傳播方向上進行局部位移震盪，進而形成明暗相間的「壓縮帶」與「稀疏帶」向外擴散。大缽產生較大、波長較長、震頻較低的宏觀粒子聲波；小缽產生高頻、精細且傳播敏捷的細緻波紋。",
					guide: "【傳播方向】可切換為向外擴散、向內共鳴或內外全向擴散；【頌缽尺寸】大缽產生慢速低頻的粗粒子波，小缽產生高頻細密粒子波；【激發方式】選擇磨缽共振（持續發出旋轉聲波，需滑鼠在圈外畫圓）或敲擊瞬態（在圈內點擊即可發射出環狀擴散聲波）。",
					why: "一般人在聆聽頌缽時，往往只能「聽見」聲音，卻無法想像聲波在空間中的實體形態。本模擬將無形的空氣震動「粒子化」，讓觀賞者能以視覺直觀看見聲波如何從缽壁擴散、在缽內聚集共鳴，理解聲音共振的立體物理形態。",
					references: [
						"Faraday, M. (1831). On a peculiar class of acoustical figures. Phil. Trans. R. Soc. (聲學幾何共振奠基研究)",
						"Terwagne, D., & Bush, J. W. (2011). Tibetan singing bowls. American Journal of Physics. (頌缽聲學與邊界震盪物理考究)"
					]
				},
				drum: {
					title: "框鼓共振與二維膜貝塞爾波",
					focus: "本模型討論二維圓形鼓面皮膜（Membrane）受到敲擊時產生的彈性波動模式，以及張力、阻尼與聲學諧波（Harmonics）的震動形態。",
					principle: "圓形膜震動遵循二維波動方程式，其在極坐標下的穩態解由貝塞爾函數（Bessel Functions）與餘弦函數決定。不同的點擊位置與敲擊力道，會激發出不同的振動模態 (n,m)。本模型使用斜角 3D 粒子格柵，將垂直於鼓面的 Z 軸位移放大投影，直觀呈現鼓皮如何將動能轉化為複雜的三維簡諧運動。",
