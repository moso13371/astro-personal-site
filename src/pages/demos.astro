			// Initial state generators
			function generateGrid() {
				gridPoints = [];
				const cols = Math.ceil(width / 22) + 2;
				const rows = Math.ceil(height / 22) + 2;
				for (let x = -1; x < cols; x++) {
					for (let y = -1; y < rows; y++) {
						gridPoints.push({ origX: x * 22, origY: y * 22 });
					}
				}
			}

			function generateDrum() {
				drumNodes = [];
				const radius = Math.min(width, height) * 0.35;
				const cols = 35;
				const rows = 35;

				for (let x = -cols/2; x <= cols/2; x++) {
					for (let y = -rows/2; y <= rows/2; y++) {
						const px = x * (radius * 2 / cols);
						const py = y * (radius * 2 / rows);
						const dist = Math.sqrt(px * px + py * py);
						if (dist < radius) {
							drumNodes.push({
								x: px,
								y: py,
								origX: px,
								origY: py,
								z: 0, 
								velocity: 0 
							});
						}
					}
				}
			}

			function generateDmt() {
				dmtParticles = [];
				for (let i = 0; i < 900; i++) {
					dmtParticles.push({
						r: Math.random() * Math.max(width, height) * 0.75, // Full screen
						theta: Math.random() * Math.PI * 2,
						speed: 0.4 + Math.random() * 1.6,
						alpha: 0.1 + Math.random() * 0.7,
						colorIndex: Math.floor(Math.random() * 3)
					});
				}
			}

			// Run all initializations
			generateGrid();
			generateDrum();
			generateDmt();

			// Resize Handler
			window.addEventListener('resize', () => {
				width = canvas.width = window.innerWidth;
				height = canvas.height = window.innerHeight;
				generateGrid();
				generateDrum();
				generateDmt();
			});

			// Cursor Interactions
			overlay.addEventListener('mousemove', (e) => {
				mouseX = e.clientX;
				mouseY = e.clientY;
				mouseActive = true;
			});
			overlay.addEventListener('mouseleave', () => { mouseActive = false; });
			overlay.addEventListener('mousedown', (e) => {
				mouseX = e.clientX;
				mouseY = e.clientY;
				mouseActive = true;
				handleStrike(e.clientX, e.clientY);
			});

			// Mobile touch interactions
			overlay.addEventListener('touchmove', (e) => {
				if (e.touches.length > 0) {
					mouseX = e.touches[0].clientX;
					mouseY = e.touches[0].clientY;
					mouseActive = true;
				}
			});
			overlay.addEventListener('touchend', () => { mouseActive = false; });
			overlay.addEventListener('touchstart', (e) => {
				if (e.touches.length > 0) {
					mouseX = e.touches[0].clientX;
					mouseY = e.touches[0].clientY;
					mouseActive = true;
					handleStrike(e.touches[0].clientX, e.touches[0].clientY);
				}
			});

			// Handle strikes / knocks
			function handleStrike(x, y) {
				const cx = width / 2;
				const cy = height / 2;

				if (currentTab === 'drum') {
					const dx = x - cx;
					const dy = y - cy;
					const strikePower = parseFloat(pdPower.value);

					drumNodes.forEach(node => {
						const ndx = node.x - dx;
						const ndy = node.y - dy;
						const dist = Math.sqrt(ndx * ndx + ndy * ndy);
						if (dist < 80) {
							const force = Math.exp(-(dist * dist) / 1200) * strikePower;
							node.velocity += force;
						}
					});
				} else if (currentTab === 'bowl') {
					// Strike Singing Bowl: emit a massive expanding wave of sound particles
					const bAction = pbAction.value;
					const bSize = pbSize.value;
					const bAmp = parseFloat(pbAmp.value);
					const bowlRadius = Math.min(width, height) * (bSize === 'large' ? 0.38 : 0.28);
					
					const dx = x - cx;
					const dy = y - cy;
					const dist = Math.sqrt(dx * dx + dy * dy);

					// Strike inside the bowl
					if (bAction === 'strike' && dist < bowlRadius) {
						// Spawn 350 particles in a concentric ring representing the impact shockwave
						for (let i = 0; i < 380; i++) {
							const angle = (i / 380) * Math.PI * 2;
							soundWaveParticles.push({
								angle: angle,
								distTraveled: 0,
								speed: 2.5 + Math.random() * 1.5,
								amplitude: bAmp * 1.5,
								opacity: 1.0,
								direction: 'both' // Hitting propagates both inward and outward
							});
						}
					}
				}
			}

			// Update Text Info Panel Content
			function updateInfoPanel(tabKey) {
				const info = tabDescriptions[tabKey];
