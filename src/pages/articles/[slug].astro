---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const formatDate = (date: Date) => {
  return date.toISOString().split('T')[0].replace(/-/g, '.');
};
---

<Layout title={post.data.title} description={post.data.summary} articlePublishDate={post.data.publishDate}>
  <div class="back-link-container">
    <a href="/articles" class="back-link">
      <span class="arrow">&larr;</span> 返回文章列表
    </a>
  </div>
  
  <article class="article-content">
    <div class="article-meta">
      發佈日期：{formatDate(post.data.publishDate)}
      {post.data.isDraft && <span class="draft-badge">草稿</span>}
    </div>
    <h1 class="article-title">{post.data.title}</h1>
    
    {post.data.tags && post.data.tags.length > 0 && (
      <div class="article-tags">
        {post.data.tags.map(tag => (
          <span class="tag">#{tag}</span>
        ))}
      </div>
    )}

    {post.data.heroImage && (
      <img src={post.data.heroImage} class="article-hero-image" alt={post.data.title} />
    )}

    <div class="article-body">
      <Content />
    </div>
  </article>
</Layout>

<style>
  .back-link-container {
    margin-bottom: 3rem;
  }

  .back-link {
    font-size: 0.9rem;
    color: var(--text-muted);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .back-link:hover {
    color: var(--accent-color);
  }

  .back-link .arrow {
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .back-link:hover .arrow {
    transform: translateX(-4px);
  }

  .article-content {
    animation: fadeIn 1s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .article-meta {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
    letter-spacing: 2px;
    font-family: var(--font-serif);
  }

  .article-title {
    margin-bottom: 4rem;
    font-weight: 300;
    line-height: 1.4;
    color: var(--text-color);
    letter-spacing: 1.5px;
    font-size: 2.2rem;
    font-family: var(--font-serif);
  }

  .article-title::after {
    content: '';
    display: block;
    width: 60px;
    height: 1px;
    background-color: var(--accent-color);
    margin-top: 1.5rem;
    opacity: 0.5;
  }

  .article-body {
    line-height: 2.1;
    font-family: var(--font-serif);
    font-size: 1.08rem;
    color: #c9c2b4; /* Slightly brighter for reading readability */
    font-weight: 300;
  }

  /* Target markdown elements inside body */
  .article-body :global(p) {
    margin-bottom: 2rem;
    text-align: justify;
  }

  .article-body :global(h2) {
    font-size: 1.5rem;
    margin-top: 3.5rem;
    margin-bottom: 1.5rem;
    color: var(--text-color);
  }

  .article-body :global(h3) {
    font-size: 1.25rem;
    margin-top: 2.5rem;
    margin-bottom: 1.2rem;
    color: var(--text-color);
  }

  .article-body :global(strong) {
    color: var(--text-color);
    font-weight: 400;
    box-shadow: inset 0 -3px 0 rgba(196, 180, 156, 0.2); /* Subtle Kintsugi highlight under strong elements */
  }

  .article-body :global(ul), .article-body :global(ol) {
    margin-bottom: 2rem;
    padding-left: 1.5rem;
    color: var(--text-muted);
  }

  .article-body :global(li) {
    margin-bottom: 0.75rem;
  }

  .draft-badge {
    font-size: 0.7rem;
    background: rgba(192, 176, 153, 0.12);
    color: var(--accent-color);
    border: 1px dashed var(--accent-color);
    padding: 2px 8px;
    border-radius: 2px;
    margin-left: 1rem;
    font-family: var(--font-sans);
    vertical-align: middle;
  }

  .article-tags {
    display: flex;
    gap: 0.75rem;
    margin-top: -3.2rem;
    margin-bottom: 4rem;
    flex-wrap: wrap;
  }

  .article-tags .tag {
    font-size: 0.8rem;
    color: var(--text-muted);
    background: rgba(255, 255, 255, 0.01);
    padding: 2px 10px;
    border: 1px solid var(--border-color);
    font-family: var(--font-serif);
  }

  .article-hero-image {
    width: 100%;
    max-height: 380px;
    object-fit: cover;
    border: 1px solid var(--border-color);
    margin-bottom: 4rem;
    filter: grayscale(0.2) contrast(1.02);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
  }
</style>

