---
import Layout from '../layouts/Layout.astro';
---

<Layout title="模型 MODEL">
	<div class="model-page" aria-label="TAPARA particle field model">
		<canvas id="model-ripple-canvas"></canvas>
	</div>
</Layout>

<style>
	.model-page { position: fixed !important; inset: 0 !important; width: 100vw !important; height: 100vh !important; overflow: hidden; background: #050505; z-index: 0; }
	#model-ripple-canvas { position: absolute; inset: 0; width: 100% !important; height: 100% !important; display: block; }
	:global(.container footer) { display: none; }
	:global(body:has(.model-page) header) { background: transparent; backdrop-filter: none; -webkit-backdrop-filter: none; border-bottom: 0; }
	@media (prefers-reduced-motion: reduce) { #model-ripple-canvas { opacity: .65; } }
</style>

	<script>
		const initModel = () => {
			const canvas = document.getElementById('model-ripple-canvas') as HTMLCanvasElement | null;
			const ctx = canvas?.getContext('2d');
			if (!canvas || !ctx) return;
			const modelPage = canvas.closest('.model-page');
			if (modelPage && modelPage.parentElement !== document.body) document.body.appendChild(modelPage);
			const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
			const isMobile = window.matchMedia('(max-width: 768px)').matches;
			const frameInterval = 1000 / (isMobile ? 24 : 30);
			let w = 0, h = 0, dpr = 1, time = 0;
			let lastFrame = 0;
			let animationFrame = 0;
			let particles: Array<{ x: number; y: number; phase: number; size: number; alpha: number }> = [];
			const resize = () => {
				dpr = Math.min(window.devicePixelRatio || 1, 2); w = window.innerWidth; h = window.innerHeight;
				canvas.width = w * dpr; canvas.height = h * dpr; ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
				const particleCount = reducedMotion
					? Math.min(1800, Math.max(900, Math.floor(w * h / 700)))
					: isMobile
						? Math.min(4500, Math.max(2800, Math.floor(w * h / 260)))
						: Math.min(8000, Math.max(5000, Math.floor(w * h / 190)));
				particles = Array.from({ length: particleCount }, () => ({
					x: Math.random() * w, y: Math.random() * h, phase: Math.random() * Math.PI * 2,
					size: .55 + Math.random() * .75, alpha: .08 + Math.random() * .32
				}));
			};
			resize(); window.addEventListener('resize', resize);
			const draw = () => {
				time += 0.003;
				ctx.fillStyle = 'rgba(0, 0, 0, 0.28)'; ctx.fillRect(0, 0, w, h);
				const sources = [
					{ x: w * (.26 + Math.sin(time * .19) * .08), y: h * (.30 + Math.cos(time * .15) * .06), phase: 0 },
					{ x: w * (.73 + Math.cos(time * .14) * .07), y: h * (.58 + Math.sin(time * .17) * .07), phase: 2.4 },
					{ x: w * (.48 + Math.sin(time * .11) * .05), y: h * (.80 + Math.cos(time * .13) * .04), phase: 4.7 }
				];
				for (const particle of particles) {
					let pushX = Math.sin(particle.y * .004 + time + particle.phase) * 1.5;
					let pushY = Math.cos(particle.x * .004 - time + particle.phase) * 1.5;
					let resonance = 0;
					for (const source of sources) {
						const dx = particle.x - source.x, dy = particle.y - source.y;
						const distance = Math.hypot(dx, dy) + 1;
						const wave = Math.sin(distance * .028 - time * 1.35 + source.phase);
						const envelope = .42 + .58 * Math.exp(-distance / 560);
						const force = wave * envelope * 8;
						pushX += dx / distance * force;
						pushY += dy / distance * force;
						resonance += (wave + 1) * envelope * .16;
					}
					const x = particle.x + pushX;
					const y = particle.y + pushY;
					const alpha = Math.min(.58, particle.alpha + resonance * .8);
					ctx.fillStyle = `rgba(0, ${105 + resonance * 70}, ${145 + resonance * 45}, ${alpha})`;
					ctx.fillRect(x, y, particle.size, particle.size);
				}
			};

			const animate = (now: number) => {
				if (now - lastFrame >= frameInterval) {
					draw();
					lastFrame = now;
				}
				animationFrame = requestAnimationFrame(animate);
			};

			const updateVisibility = () => {
				if (document.hidden) {
					cancelAnimationFrame(animationFrame);
					animationFrame = 0;
				} else if (!reducedMotion && !animationFrame) {
					lastFrame = performance.now();
					animationFrame = requestAnimationFrame(animate);
				}
			};

			document.addEventListener('visibilitychange', updateVisibility);
			if (reducedMotion) draw();
			else animationFrame = requestAnimationFrame(animate);
		};

		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', initModel, { once: true });
		} else {
			initModel();
		}
	</script>
